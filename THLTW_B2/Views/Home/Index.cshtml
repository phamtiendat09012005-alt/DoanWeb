@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="hero_area">
    <section class="slider_section">
        <div class="slider_container">
            <div id="carouselExampleIndicators" class="carousel slide" data-ride="carousel">
                <ol class="carousel-indicators">
                    <li data-target="#carouselExampleIndicators" data-slide-to="0" class="active">01</li>
                    <li data-target="#carouselExampleIndicators" data-slide-to="1">02</li>
                    <li data-target="#carouselExampleIndicators" data-slide-to="2">03</li>
                </ol>
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-md-6 px-0">
                                    <div class="img-box">
                                        <img src="/images/User/thi-cong-san-bong-da-mini-9.webp" alt="Sân bóng đá mặt cỏ đẹp" style="object-fit: cover; height: 100%; border-radius: 10px;" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-box">
                                        <h1>
                                            Mặt Cỏ <br />
                                            <span>Chuẩn FIFA</span>
                                        </h1>
                                        <p>
                                            Trải nghiệm không gian thi đấu đỉnh cao với hệ thống sân cỏ nhân tạo thế hệ mới nhất, êm ái và chống trơn trượt hoàn hảo.
                                        </p>
                                        <a asp-controller="DatSan" asp-action="Index">Đặt Sân Ngay</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-md-6 px-0">
                                    <div class="img-box">
                                        <img src="/images/User/unnamed.jpg" alt="Ghép kèo" style="object-fit: cover; height: 100%; border-radius: 10px;" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-box">
                                        <h1>
                                            Tìm Đối Thủ <br />
                                            <span>Dễ Dàng</span>
                                        </h1>
                                        <p>
                                            Đội bạn đang muốn giao lưu cọ xát? Tính năng "Cáp Kèo" của chúng tôi sẽ giúp bạn tìm đối thủ ngang tầm.
                                        </p>
                                        <a asp-controller="TimDoiThu" asp-action="Index">Tạo Kèo Mới</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-md-6 px-0">
                                    <div class="img-box">
                                        <img src="/images/User/unnamed (1).jpg" alt="Dịch vụ tiện ích" style="object-fit: cover; height: 100%; border-radius: 10px;" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-box">
                                        <h1>
                                            Cửa Hàng <br />
                                            <span>Đa Dạng</span>
                                        </h1>
                                        <p>
                                            Phục vụ tận sân với menu nước giải khát phong phú, cho thuê áo bíp, bóng thi đấu và cung cấp các phụ kiện thể thao.
                                        </p>
                                        <a href="/CuaHang">Xem Dịch Vụ</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="carousel_btn-box">
                    <a class="carousel-control-prev" href="#carouselExampleIndicators" role="button" data-slide="prev">
                        <span class="sr-only">Previous</span>
                    </a>
                    <img src="/Temp/images/User/line.png" alt="" />
                    <a class="carousel-control-next" href="#carouselExampleIndicators" role="button" data-slide="next">
                        <span class="sr-only">Next</span>
                    </a>
                </div>
            </div>
        </div>
    </section>
</div>

<section class="vip_banner_section py-4 my-5" style="background: linear-gradient(135deg, #1a1a1a 0%, #333 100%); border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.15);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8 text-center text-md-start mb-3 mb-md-0">
                <h3 class="fw-bold text-warning mb-2"><i class="fa-solid fa-crown me-2"></i> Trở thành Hội Viên VIP</h3>
                <p class="text-white mb-0" style="opacity: 0.8;">Mở khóa đặc quyền đặt <strong>Giờ Vàng</strong>, bao trọn nhiều sân cùng lúc và ưu tiên cáp kèo.</p>
            </div>
            <div class="col-md-4 text-center text-md-end">
                <a asp-controller="Vip" asp-action="Index" class="btn btn-warning fw-bold py-3 px-4 text-dark shadow rounded-pill">
                    NÂNG CẤP NGAY <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>
</section>

<section id="services-section" class="service_section layout_padding">
    <div class="container">
        <div class="heading_container">
            <h2>
                Dịch <span>Vụ</span> Của Chúng Tôi
            </h2>
            <p>
                Hệ thống QLSBMini cung cấp trải nghiệm thể thao trọn vẹn từ lúc đặt lịch cho đến khi tiếng còi mãn cuộc vang lên.
            </p>
        </div>
        <div class="row">
            <div class="col-lg-6 ">
                <div class="img-container tab-content">
                    <div class="img-box tab-pane fade show active" id="img1" role="tabpanel">
                        <img src="/images/User/Chelsea-Fifa.jpeg" alt="Thuê sân bóng" style="border-radius: 10px;" />
                    </div>
                    <div class="img-box tab-pane fade" id="img2" role="tabpanel">
                        <img src="/images/User/chelsea-1803072322.jpg" alt="Ghép kèo" style="border-radius: 10px;" />
                    </div>
                    <div class="img-box tab-pane fade" id="img3" role="tabpanel">
                        <img src="/images/User/Palmer-Penalty-Evert-01.jpg" alt="Cho thuê dụng cụ" style="border-radius: 10px;" />
                    </div>
                    <div class="img-box tab-pane fade" id="img4" role="tabpanel">
                        <img src="/images/User/chel-jpg-1356513760-1356514033.webp" alt="Giải khát" style="border-radius: 10px;" />
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="detail-container nav nav-tabs" id="myTab" role="tablist">
                    <div class="detail-box active" id="img1-tab" data-toggle="tab" href="#img1" role="tab" aria-selected="true">
                        <h4>
                            Khoảnh Khắc <br />
                            Vinh Quang
                        </h4>
                    </div>
                    <div class="detail-box" id="img2-tab" data-toggle="tab" href="#img2" role="tab" aria-selected="false">
                        <h4>
                            Tinh Thần <br />
                            Đồng Đội
                        </h4>
                    </div>
                    <div class="detail-box" id="img3-tab" data-toggle="tab" href="#img3" role="tab" aria-selected="false">
                        <h4>
                            Tranh chấp bóng <br />
                            Rực Cháy
                        </h4>
                    </div>
                    <div class="detail-box" id="img4-tab" data-toggle="tab" href="#img4" role="tab" aria-selected="false">
                        <h4>
                            Huy chương <br />
                            giải đấu
                        </h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="portfolio_section">
    <div class="heading_container">
        <h2>
            Thư <span>Viện</span> Hình Ảnh
        </h2>
        <p>
            Những khoảnh khắc rực cháy trên sân cỏ QLSBMini của các chân sút phong trào.
        </p>
    </div>
    <div class="portfolio_container layout_padding">
        <div class="box-1">
            <div class="img-box b-1">
                <img src="/images/User/au-da-san-phui-16194077549642101926744.webp" alt="Trận đấu 1">
            </div>
            <div class="img-box b-2">
                <img src="/images/User/ky-thuat-choi-tren-san-bong-da-mini-5-nguoi-can-biet__(2).jpg" alt="Trận đấu 2">
            </div>
        </div>
        <div class="box-2">
            <div class="img-box b-3">
                <img src="/images/User/bong-da-phong-trao-san-7-khu-chung-cu.jpg" alt="Trận đấu 3">
            </div>
            <div class="img-box b-4">
                <img src="/images/User/san-bong-da-nhan-tao-nha-trang-2.jpg" alt="Trận đấu 4">
            </div>
        </div>
    </div>
</section>

<section class="started_section layout_padding-bottom mt-5">
    <div class="container">
        <div class="row">
            <div class="col-md-7">
                <div class="detail-box">
                    <div class="heading_container">
                        <h2>
                            Bạn Đã Sẵn Sàng <span>Ra Sân</span> <br>
                            Ngay Hôm Nay?
                        </h2>
                        <p>
                            Kiểm tra lịch sân trống và đặt ngay khung giờ vàng trước khi đối thủ khác nhanh tay giành mất!
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 offset-md-1">
                <div class="btn-box d-flex flex-column gap-3">
                    <a asp-controller="DatSan" asp-action="Index" class="btn btn-primary btn-lg w-100 fw-bold mb-3">ĐẶT SÂN NGAY</a>
                    <a asp-controller="Vip" asp-action="Index" class="btn btn-outline-warning btn-lg w-100 fw-bold">MUA GÓI VIP</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="agency_section layout_padding-bottom">
    <div class="agency_container ">
        <div class="box ">
            <div class="detail-box">
                <div class="heading_container">
                    <h2>
                        Về <span>QLSBMini</span>
                    </h2>
                </div>
                <p>
                    Chúng tôi là hệ thống quản lý sân cỏ nhân tạo hiện đại nhất khu vực. Với ứng dụng công nghệ vào thể thao, QLSBMini giúp các đội bóng dễ dàng tiếp cận sân thi đấu, minh bạch trong giá cả và có thêm nhiều cơ hội giao lưu thông qua nền tảng ghép kèo tự động thông minh.
                </p>
            </div>
        </div>
    </div>
</section>