@model IEnumerable<THLTW_B2.Models.Product>

@{
    ViewData["Title"] = "Cửa Hàng Thể Thao";
}

@section Styles {
    <style>
        .store-header {
            background: linear-gradient(rgba(0, 34, 68, 0.8), rgba(0, 34, 68, 0.8)), url('https://images.unsplash.com/photo-1540747913346-19e32dc3e97e?q=80&w=2000') center/cover;
            color: white;
            padding: 80px 0;
            border-radius: 15px;
            margin-bottom: 40px;
        }

        .product-card {
            border: none;
            border-radius: 15px;
            overflow: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            height: 100%;
        }

            .product-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            }

        .product-img-wrapper {
            height: 200px;
            overflow: hidden;
            background-color: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .product-img-wrapper img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.5s ease;
            }

        .product-card:hover .product-img-wrapper img {
            transform: scale(1.1);
        }

        .category-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            background-color: #ffc107;
            color: #000;
            font-weight: bold;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.8rem;
            z-index: 2;
        }

        .price-tag {
            color: #d9534f;
            font-weight: 800;
            font-size: 1.25rem;
        }

        .btn-add-cart {
            background-color: #007bff;
            color: white;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-add-cart:hover {
                background-color: #0056b3;
                color: white;
                transform: scale(1.05);
            }
    </style>
}

<div class="container layout_padding">
    <div class="store-header text-center shadow">
        <h1 class="display-4 fw-bold text-uppercase">Tạp Hóa <span style="color: #00aaff;">Sân Phủi</span></h1>
        <p class="lead text-white-50">Nước mát lạnh - Phụ kiện xịn sò - Tiếp lửa đam mê</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card product-card position-relative">
                        <span class="category-badge shadow-sm">@(item.Category != null ? item.Category.Name : "Khác")</span>

                        <div class="product-img-wrapper">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)"
                                 alt="@item.Name"
                                 onerror="this.src='https://via.placeholder.com/300x200?text=No+Image'">
                        </div>

                        <div class="card-body text-center d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark mb-2" style="font-size: 1.1rem;">@item.Name</h5>

                            <p class="text-muted small mb-1">
                                Đơn vị: @(string.IsNullOrEmpty(item.Unit) ? "Cái" : item.Unit)
                                | Tồn: @item.StockQuantity
                            </p>

                            <p class="price-tag mb-3 mt-auto">@item.Price.ToString("#,##0") VNĐ</p>

                            @if (item.StockQuantity > 0)
                            {
                                <a asp-controller="GioHang" asp-action="AddToCart" asp-route-id="@item.ProductId" class="btn btn-add-cart w-100 py-2">
                                    <i class="fa-solid fa-cart-plus me-1"></i> Thêm Vào Giỏ
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-secondary w-100 py-2 fw-bold rounded-pill" disabled>
                                    <i class="fa-solid fa-ban me-1"></i> HẾT HÀNG
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fa-solid fa-box-open fa-4x text-muted mb-3"></i>
                <h4 class="text-muted">Cửa hàng hiện chưa có sản phẩm nào.</h4>
            </div>
        }
    </div>
</div>