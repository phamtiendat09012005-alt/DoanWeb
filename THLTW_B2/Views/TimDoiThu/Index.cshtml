@model IEnumerable<THLTW_B2.Models.MatchRequest>
@using Microsoft.AspNetCore.Identity
@inject UserManager<THLTW_B2.Models.ApplicationUser> UserManager

@{
    ViewData["Title"] = "Tìm Đối Thủ Giao Lưu";
    var currentUser = await UserManager.GetUserAsync(User);
}

@section Styles {
    <style>
        #matchBoard {
            background-color: #1e1e1e !important;
            border-radius: 8px;
            height: 550px;
            overflow-y: auto;
        }

        .match-date-header {
            color: #ffffff;
            padding: 15px 20px;
            font-size: 1.1rem;
            border-bottom: 1px solid #333333;
            background-color: #1e1e1e;
            position: sticky;
            top: 0;
            z-index: 5;
        }

        .match-card {
            background-color: #2b2b2b;
            color: #ffffff;
            border: 1px solid #333333;
            padding: 15px 20px;
            margin: 10px;
            border-radius: 8px;
            transition: 0.2s;
        }

            .match-card:hover {
                background-color: #333333;
                transform: translateY(-2px);
                border-color: #0d6efd;
            }

        .team-icon {
            width: 24px;
            height: 18px;
            margin-right: 12px;
            border-radius: 2px;
            object-fit: cover;
        }

        .match-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        @@media (max-width: 768px) {
            .match-grid {
                grid-template-columns: 1fr;
            }
        }

        /* CSS FIX LOGO TRÒN VÀ KHÔNG ĐÈ CHỮ */
        #statLogo {
            width: 120px;
            height: 120px;
            object-fit: cover;
            border-radius: 50% !important;
            border: 5px solid #fff;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            background: #fff;
        }

        .stat-header {
            background: #212529;
            height: 100px;
            position: relative;
        }
    </style>
}

<div class="container mt-5 mb-5">
    <div class="row mb-4 text-center">
        <div class="col-12">
            <h2 class="fw-bold text-uppercase"><i class="bi bi-lightning-fill text-warning"></i> Hệ thống cáp kèo trực tuyến</h2>
            <p class="text-muted">Đăng tin và bắt kèo ngay lập tức (Real-time)</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow border-0 mb-4">
                <div class="card-header bg-dark text-white fw-bold py-3">Tạo Kèo Mới</div>
                <div class="card-body p-4">
                    @if (ViewBag.IsMember != null && (bool)ViewBag.IsMember)
                    {
                        <div class="mb-3"><label class="form-label fw-bold small">Ngày thi đấu *</label><input type="date" id="dateInput" class="form-control"></div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Khung giờ *</label>
                            <select id="timeSlotInput" class="form-select">
                                <option value="06:00 - 07:30">06:00 - 07:30 (Sáng sớm)</option>
                                <option value="07:30 - 09:00">07:30 - 09:00</option>
                                <option value="09:00 - 10:30">09:00 - 10:30</option>
                                <option value="10:30 - 12:00">10:30 - 12:00</option>

                                <option value="14:30 - 16:00">14:30 - 16:00</option>
                                <option value="16:00 - 17:30">16:00 - 17:30</option>

                                <option value="17:30 - 19:00" selected>17:30 - 19:00 (Giờ vàng)</option>
                                <option value="19:00 - 20:30">19:00 - 20:30 (Giờ vàng)</option>
                                <option value="20:30 - 22:00">20:30 - 22:00 (Giờ vàng)</option>
                            </select>
                        </div>
                        <div class="mb-3"><label class="form-label fw-bold small">Tên đội</label><input type="text" id="teamNameInput" class="form-control bg-light" value="@ViewBag.MyTeamName" readonly></div>
                        <div class="mb-3"><label class="form-label fw-bold small">Số điện thoại</label><input type="text" id="phoneInput" class="form-control" value="@currentUser?.PhoneNumber"></div>

                        <div class="mb-3">
                         
                            <div class="mb-3">
                                <label class="form-label fw-bold small">Tiền cọc (15% giá sân) <span class="text-danger">*</span></label>
                                <input type="number" id="depositInput" class="form-control fw-bold text-danger bg-light" value="0" readonly>
                            </div>
                        </div>

                        <div class="alert alert-info py-2 mb-3 small"><strong id="selectedPitchName">Chưa chọn sân</strong> - <span id="selectedPitchPrice">0đ</span></div>
                        <button type="button" class="btn btn-outline-primary w-100 mb-2 fw-bold" onclick="checkAvailablePitches()">Chọn sân</button>
                        <button id="sendButton" class="btn btn-primary w-100 fw-bold">Đăng Kèo</button>
                    }
                    else
                    {
                        <div class="text-center py-4"><a asp-controller="HoiVien" asp-action="DangKy" class="btn btn-warning fw-bold">Đăng ký Hội viên để sử dụng</a></div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white fw-bold py-3">Kèo Đang Chờ Đối Thủ</div>
                <div class="card-body p-0" id="matchBoard">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var group in Model.GroupBy(m => m.MatchDate.ToString("dddd, dd/MM/yyyy")))
                        {
                            <div class="match-date-header">@group.Key</div>
                            <div class="match-grid">
                                @foreach (var item in group)
                                {
                                    <div class="match-card">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div onclick="viewTeamStats('@item.TeamName')" style="cursor:pointer" class="fw-bold text-primary">@item.TeamName</div>
                                            @if (item.Status == "Đang chờ đối thủ")
                                            {
                                                <button class="btn btn-sm btn-success rounded-pill px-3 fw-bold" onclick="openAcceptModal('@item.TeamName', @item.Id, @item.TienCoc)">Nhận Kèo</button>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary rounded-pill px-3">VS @item.OpponentName</span>
                                            }
                                        </div>
                                        <div class="mt-2 small opacity-75"><i class="bi bi-clock"></i> @item.TimeSlot | <i class="bi bi-geo-alt"></i> @item.PitchName</div>
                                        <div class="mt-1 small text-warning fw-bold"><i class="bi bi-cash"></i> Đã cọc: @item.TienCoc.ToString("N0") đ</div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNhanKeo" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold">Xác nhận Nhận Kèo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <div class="text-start mb-3">
                    <label class="form-label fw-bold small">Đội của bạn:</label>
                    <input type="text" id="acceptorNameInput" class="form-control" value="@ViewBag.MyTeamName" placeholder="Tên đội nhận kèo">
                </div>
                <p class="mb-2">Vui lòng quét mã QR chuyển cọc <strong id="qrAcceptAmountDisplay" class="text-danger fs-5">0đ</strong>:</p>
                <div class="bg-light p-3 rounded-4 mb-3 border shadow-sm">
                    <img id="qrCodeImg" src="" class="img-fluid rounded mb-2" style="max-width: 180px; border: 3px solid #fff;">
                    <h6 class="mt-2 fw-bold text-primary mb-0" id="qrNoteText">NỘI DUNG: NHANKEO</h6>
                </div>
                <button type="button" class="btn btn-success w-100 fw-bold py-2 shadow" onclick="confirmPayment()">TÔI ĐÃ CHUYỂN KHOẢN</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalTaoKeo" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold">Xác nhận Đặt Cọc Kèo Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p class="mb-2">Vui lòng quét mã QR để chuyển cọc <strong id="qrDepositAmountDisplay" class="text-danger fs-5">100,000đ</strong>:</p>

                <div class="bg-light p-3 rounded-4 mb-3 border shadow-sm">
                    <img id="qrCodeImgTaoKeo" src="" class="img-fluid rounded mb-2" style="max-width: 180px; border: 3px solid #fff;">
                    <h6 class="mt-2 fw-bold text-primary mb-0" id="qrNoteTextTaoKeo">NỘI DUNG: TAOKEO</h6>
                </div>

                <div class="alert alert-warning py-2 small mb-3">
                    <i class="bi bi-info-circle"></i> Vui lòng giữ nguyên nội dung chuyển khoản để hệ thống duyệt.
                </div>

                <button type="button" class="btn btn-primary w-100 fw-bold py-2 shadow" onclick="confirmCreateMatchPayment(this)">
                    <i class="bi bi-check-circle"></i> TÔI ĐÃ CHUYỂN KHOẢN
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="teamStatsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden text-center">
            <div class="stat-header"></div>
            <div class="modal-body px-4 pb-5 pt-0">
                <div style="margin-top: -60px; position: relative; z-index: 10;"><img id="statLogo" src="/images/default-logo.png"></div>
                <h3 class="fw-bold text-uppercase mt-3" id="statTeamName">TÊN ĐỘI</h3>
                <div class="row g-2 my-4">
                    <div class="col-4"><div class="p-2 bg-success bg-opacity-10 rounded-3 text-success"><h4 class="fw-bold mb-0" id="statWins">0</h4><small>Thắng</small></div></div>
                    <div class="col-4"><div class="p-2 bg-secondary bg-opacity-10 rounded-3 text-secondary"><h4 class="fw-bold mb-0" id="statDraws">0</h4><small>Hòa</small></div></div>
                    <div class="col-4"><div class="p-2 bg-danger bg-opacity-10 rounded-3 text-danger"><h4 class="fw-bold mb-0" id="statLosses">0</h4><small>Thua</small></div></div>
                </div>
                <div class="p-3 bg-light rounded-4 text-start">
                    <div class="d-flex justify-content-between mb-1"><span class="small fw-bold">Tỉ lệ thắng</span><span class="small fw-bold text-primary" id="statWinRateText">0%</span></div>
                    <div class="progress mb-3" style="height: 8px;"><div class="progress-bar progress-bar-striped progress-bar-animated" id="statWinRateBar" style="width: 0%"></div></div>
                    <div class="d-flex justify-content-between"><span class="small fw-bold">FairPlay</span><span class="badge bg-success" id="statFairPlay">100/100</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="pitchModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header bg-dark text-white py-2"><h6>Chọn sân thi đấu</h6></div><div class="modal-body list-group p-0" id="pitchListContainer"></div></div></div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder().withUrl("/matchHub").build();
        let currentMatchId = 0, currentPoster = "";
        let pendingMatchData = null; // Biến lưu tạm dữ liệu kèo mới

        connection.start().then(() => console.log("SignalR: Ready")).catch(e => console.error(e));
        // 1. KHÓA NGÀY QUÁ KHỨ VÀ RESET SÂN KHI ĐỔI GIỜ
        document.addEventListener("DOMContentLoaded", function() {
            // Lấy ngày hôm nay chuẩn theo múi giờ để set thuộc tính min
            let today = new Date();
            let tzoffset = today.getTimezoneOffset() * 60000;
            let localISOTime = (new Date(today - tzoffset)).toISOString().slice(0, 10);

            // Ép ô Date không cho chọn ngày hôm qua trở về trước
            document.getElementById("dateInput").setAttribute('min', localISOTime);

            // Khách lươn lẹo đổi giờ sau khi đã chọn sân => Bắt chọn lại sân từ đầu
            document.getElementById("dateInput").addEventListener("change", resetPitch);
            document.getElementById("timeSlotInput").addEventListener("change", resetPitch);
        });

        function resetPitch() {
            document.getElementById("selectedPitchName").innerText = "Chưa chọn sân";
            document.getElementById("selectedPitchPrice").innerText = "0đ";
            document.getElementById("depositInput").value = "0";
        }
        // --- XỬ LÝ NHẬN KÈO CŨ ---
        function openAcceptModal(poster, id, tienCoc) {
            currentPoster = poster;
            currentMatchId = id;
            document.getElementById("qrAcceptAmountDisplay").innerText = tienCoc.toLocaleString() + " VNĐ";
            document.getElementById("qrNoteText").innerText = "NỘI DUNG: NHANKEO_" + id;
            document.getElementById("qrCodeImg").src = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=NHANKEO_${id}_${tienCoc}`;
            new bootstrap.Modal(document.getElementById('modalNhanKeo')).show();
        }

        function confirmPayment() {
            const accName = document.getElementById("acceptorNameInput").value || "Đội Demo Đồ Án";

            if (currentMatchId === 0) {
                alert("Lỗi: Vui lòng thử lại!");
                return;
            }

            connection.invoke("AcceptMatch", currentMatchId, currentPoster, accName, "0900000000")
                .then(() => {
                    alert("Xác nhận thành công! Kèo đã được chốt.");
                    location.reload();
                })
                .catch(e => {
                    console.log("SignalR Error but continuing demo...");
                    alert("Hệ thống demo: Ghi nhận cọc thành công!");
                    location.reload();
                });
        }

        // --- XỬ LÝ XEM THỐNG KÊ & CHỌN SÂN ---
        async function viewTeamStats(teamName) {
            try {
                const r = await fetch(`/TimDoiThu/GetTeamStats?teamName=${encodeURIComponent(teamName)}`);
                const d = await r.json();
                if (!d.success) return alert("Đội chưa đăng ký hội viên!");
                document.getElementById('statTeamName').innerText = d.teamName;
                document.getElementById('statLogo').src = d.logoUrl || "/images/default-logo.png";
                document.getElementById('statWins').innerText = d.wins;
                document.getElementById('statDraws').innerText = d.draws;
                document.getElementById('statLosses').innerText = d.losses;
                document.getElementById('statWinRateText').innerText = d.winRate + '%';
                document.getElementById('statWinRateBar').style.width = d.winRate + '%';
                new bootstrap.Modal(document.getElementById('teamStatsModal')).show();
            } catch (e) { alert("Lỗi tải thông tin!"); }
        }
        function tinhSoGioDa(khungGio) {
            try {
                // Tách "17:30 - 19:00" ra thành 2 khoảng
                let gio = khungGio.split('-');
                let batDau = gio[0].trim().split(':');
                let ketThuc = gio[1].trim().split(':');

                // Đổi ra phút để trừ cho dễ
                let phutBatDau = parseInt(batDau[0]) * 60 + parseInt(batDau[1]);
                let phutKetThuc = parseInt(ketThuc[0]) * 60 + parseInt(ketThuc[1]);

                // Trả về số giờ (90 phút / 60 = 1.5 giờ)
                return (phutKetThuc - phutBatDau) / 60;
            } catch (e) {
                return 1.5; // Mặc định 1.5 tiếng nếu có lỗi
            }
        }
        // --- XỬ LÝ CHỌN SÂN TỰ TÍNH 15% ---
        // 2. HÀM TÌM SÂN VÀ HIỂN THỊ TỔNG TIỀN (Có chặn giờ quá khứ)
        async function checkAvailablePitches() {
            const dateVal = document.getElementById("dateInput").value;
            const timeVal = document.getElementById("timeSlotInput").value;
            if (!dateVal) return alert("Vui lòng chọn ngày trước!");

            // --- KIỂM TRA THỜI GIAN: BẮT ĐẦU ---
            // Lấy giờ bắt đầu của ca đá (VD: "14:30")
            let startTimeStr = timeVal.split('-')[0].trim();
            let [hours, minutes] = startTimeStr.split(':');

            // Ghép Ngày + Giờ khách chọn thành 1 mốc thời gian hoàn chỉnh
            let selectedDateTime = new Date(dateVal);
            selectedDateTime.setHours(parseInt(hours), parseInt(minutes), 0, 0);
            let now = new Date();

            // Nếu ngày giờ khách chọn NHỎ HƠN hoặc BẰNG hiện tại => Đá văng ra
            if (selectedDateTime <= now) {
                return alert("Ca đá này đã qua rồi sếp ơi! Vui lòng chọn khung giờ hoặc ngày khác nhé.");
            }
            // --- KIỂM TRA THỜI GIAN: KẾT THÚC ---

            const soGioDa = tinhSoGioDa(timeVal);
            const r = await fetch(`/TimDoiThu/GetPitchesStatus?date=${dateVal}&timeSlot=${timeVal}`);
            const p = await r.json();
            let html = "";
            p.forEach(s => {
                let tongTien = s.price * soGioDa;

                if(!s.isBooked) {
                    html += `<button class="list-group-item list-group-item-action py-3 text-start" onclick="selectPitch('${s.name}', ${tongTien})">
                                <b class="fs-6">${s.name}</b>
                                <br/>
                                <small class="text-muted">Đơn giá: ${s.price.toLocaleString()}đ/giờ x ${soGioDa} giờ</small>
                                <span class="float-end text-success fw-bold fs-6">Tổng: ${tongTien.toLocaleString()}đ</span>
                             </button>`;
                }
            });
            document.getElementById("pitchListContainer").innerHTML = html || "<div class='p-3 text-danger fw-bold'>Hết sân trống trong khung giờ này!</div>";
            new bootstrap.Modal(document.getElementById('pitchModal')).show();
        }

        function selectPitch(n, tongTienSan) {
            document.getElementById("selectedPitchName").innerText = n;
            document.getElementById("selectedPitchPrice").innerText = "Tổng tiền: " + tongTienSan.toLocaleString() + "đ";

            // TỰ ĐỘNG TÍNH CỌC 15% CỦA TỔNG TIỀN (VD: 15% của 750k = 112,500đ)
            let tienCoc = Math.round(tongTienSan * 0.15);
            document.getElementById("depositInput").value = tienCoc;

            bootstrap.Modal.getInstance(document.getElementById('pitchModal')).hide();
        }

        // --- XỬ LÝ TẠO KÈO MỚI (FLOW QUÉT MÃ QR) ---
        document.getElementById("sendButton")?.addEventListener("click", () => {
            const u = document.getElementById("teamNameInput").value;
            const d = document.getElementById("dateInput").value;
            const t = document.getElementById("timeSlotInput").value;
            const phone = document.getElementById("phoneInput").value || "0900000000";
            const pi = document.getElementById("selectedPitchName").innerText;
            const deposit = document.getElementById("depositInput").value;

            // Validate
            if(!d) return alert("Vui lòng chọn ngày thi đấu!");
            if(pi === "Chưa chọn sân") return alert("Chọn sân trước khi đăng kèo!");
            if(!deposit || deposit < 50000) return alert("Tiền cọc tối thiểu là 50,000đ!");

            // Cất dữ liệu vào biến toàn cục để lát gửi lên server
            pendingMatchData = { user: u, date: d, time: t, phone: phone, pitch: pi, deposit: deposit };

            // Render mã QR cho chức năng Tạo Kèo
            document.getElementById("qrDepositAmountDisplay").innerText = Number(deposit).toLocaleString() + " VNĐ";
            const orderCode = "TAOKEO_" + phone.slice(-4) + "_" + Math.floor(Math.random() * 1000);
            document.getElementById("qrNoteTextTaoKeo").innerText = "NỘI DUNG: " + orderCode;
            document.getElementById("qrCodeImgTaoKeo").src = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${orderCode}_${deposit}`;

            // Mở Modal thanh toán Tạo kèo
            new bootstrap.Modal(document.getElementById('modalTaoKeo')).show();
        });

        function confirmCreateMatchPayment(btn) {
            if(!pendingMatchData) return;
            const { user, date, time, phone, pitch, deposit } = pendingMatchData;

            // Đổi state nút thành Đang xử lý
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang xử lý...';
            btn.disabled = true;

            // Đẩy dữ liệu lên Hub
            connection.invoke("FindOpponent", user, date, time, phone, pitch, deposit).then(() => {
                alert("Đăng kèo thành công! Đã ghi nhận cọc: " + Number(deposit).toLocaleString() + "đ");
                location.reload();
            }).catch(err => {
                console.error(err);
                // Demo mode fallback
                alert("Đăng kèo thành công (Demo mode). Cọc: " + Number(deposit).toLocaleString() + "đ");
                location.reload();
            });
        }
    </script>
}h