@model IEnumerable<THLTW_B2.Models.MatchRequest>
@using Microsoft.AspNetCore.Identity
@inject UserManager<THLTW_B2.Models.ApplicationUser> UserManager

@{
    ViewData["Title"] = "Tìm Đối Thủ Giao Lưu";
    var currentUser = await UserManager.GetUserAsync(User);
}

@section Styles {
    <style>
        #matchBoard {
            background-color: #1e1e1e !important;
            border-radius: 8px;
            height: 550px;
            overflow-y: auto;
        }

        .match-date-header {
            color: #ffffff;
            padding: 15px 20px;
            font-size: 1.1rem;
            border-bottom: 1px solid #333333;
            background-color: #1e1e1e;
            position: sticky;
            top: 0;
            z-index: 5;
        }

        .match-card {
            background-color: #2b2b2b;
            color: #ffffff;
            border: 1px solid #333333;
            padding: 15px 20px;
            margin: 10px;
            border-radius: 8px;
            transition: 0.2s;
        }

            .match-card:hover {
                background-color: #333333;
                transform: translateY(-2px);
                border-color: #0d6efd;
            }

        .team-icon {
            width: 24px;
            height: 18px;
            margin-right: 12px;
            border-radius: 2px;
            object-fit: cover;
        }

        .match-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        @@media (max-width: 768px) {
            .match-grid {
                grid-template-columns: 1fr;
            }
        }

        #matchBoard::-webkit-scrollbar {
            width: 6px;
        }

        #matchBoard::-webkit-scrollbar-track {
            background: #1e1e1e;
        }

        #matchBoard::-webkit-scrollbar-thumb {
            background: #444;
            border-radius: 8px;
        }

        /* CSS CHO Ô CHỈ SỐ */
        .stat-box {
            border-radius: 15px;
            padding: 15px 5px;
            text-align: center;
            border: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

            .stat-box.win {
                background: linear-gradient(135deg, #10b981, #059669);
                color: white;
            }

            .stat-box.draw {
                background: linear-gradient(135deg, #6b7280, #4b5563);
                color: white;
            }

            .stat-box.loss {
                background: linear-gradient(135deg, #ef4444, #dc2626);
                color: white;
            }

        .stat-value {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0;
        }

        .stat-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
        }
    </style>
}

<div class="container mt-5 mb-5">
    @if (ViewBag.IsMember != null && !(bool)ViewBag.IsMember)
    {
        <div class="alert alert-warning shadow border-warning rounded-4 mb-4">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="fw-bold mb-1"><i class="fa-solid fa-crown text-warning me-2"></i>Chưa đăng ký Hội viên</h5>
                    <p class="mb-0 text-dark">Bạn cần đăng ký Hội viên để tham gia hoạt động của sân.</p>
                </div>
                <a asp-controller="HoiVien" asp-action="DangKy" class="btn btn-warning fw-bold shadow-sm">Đăng ký ngay</a>
            </div>
        </div>
    }

    <div class="row mb-4 text-center">
        <div class="col-12">
            <h2 class="fw-bold text-uppercase"><i class="fa-solid fa-futbol text-qlsb-blue me-2"></i>Hệ thống cáp kèo trực tuyến</h2>
            <p class="text-muted">Đăng tin và bắt kèo ngay lập tức (Real-time)</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white fw-bold py-3">Tạo Kèo Mới</div>
                <div class="card-body p-4">
                    @if (ViewBag.IsMember != null && (bool)ViewBag.IsMember)
                    {
                        <div class="mb-3"><label class="form-label fw-semibold">Chọn ngày *</label><input type="date" id="dateInput" class="form-control"></div>
                        <div class="mb-3"><label class="form-label fw-semibold">Khung giờ *</label><select id="timeSlotInput" class="form-select"><option value="">-- Chọn khung giờ --</option><option value="06:00 - 07:30">06:00 - 07:30</option><option value="07:30 - 09:00">07:30 - 09:00</option><option value="16:00 - 17:30">16:00 - 17:30</option><option value="17:30 - 19:00">17:30 - 19:00</option><option value="19:00 - 20:30">19:00 - 20:30</option><option value="20:30 - 22:00">20:30 - 22:00</option></select></div>
                        <div class="mb-3"><label class="form-label fw-semibold">Tên đội *</label><input type="text" id="teamNameInput" class="form-control bg-light" value="@ViewBag.MyTeamName" readonly></div>
                        <div class="mb-3"><label class="form-label fw-semibold">Số điện thoại *</label><input type="text" id="phoneInput" class="form-control" value="@currentUser?.PhoneNumber" @(string.IsNullOrEmpty(currentUser?.PhoneNumber) ? "" : "readonly")></div>
                        <div class="mb-3"><label class="form-label fw-semibold">Ghi chú</label><textarea id="messageInput" class="form-control" rows="2"></textarea></div>
                        <div class="alert mb-4 py-2" style="background-color: #d1e7dd; color: #0f5132;"><strong id="selectedPitchName">Chưa chọn sân</strong><br><span class="fw-bold text-dark fs-5" id="selectedPitchPrice">0 đ</span></div>
                        <div class="d-flex justify-content-between"><button type="button" class="btn btn-info text-white fw-bold" onclick="checkAvailablePitches()">Chọn Sân</button><button id="sendButton" class="btn btn-primary fw-bold px-4">Đăng Kèo</button></div>
                    }
                    else
                    {
                        <div class="text-center py-5"><i class="fa-solid fa-lock fa-4x text-muted mb-3 opacity-50"></i><h5 class="fw-bold text-dark">Chức năng bị khóa</h5><a asp-controller="HoiVien" asp-action="DangKy" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">Đăng ký Hội viên</a></div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white fw-bold py-3">Bảng Tin Trực Tuyến</div>
                <div class="card-body p-0" id="matchBoard">
                    @if (Model != null && Model.Any())
                    {
                        var groupedMatches = Model.GroupBy(m => m.MatchDate.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN")));
                        foreach (var group in groupedMatches)
                        {
                            <div class="match-date-header">@group.Key</div>
                            <div class="match-grid" id="grid-@group.Key.Replace(" ", "").Replace(",", "").Replace("/", "")">
                                @foreach (var item in group)
                                {
                                    <div class="match-card">
                                        <div class="match-header-info"><span>Đăng lúc: @item.CreatedAt.ToString("HH:mm")</span><span class="text-warning fw-semibold">Giao hữu</span></div>
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div>
                                                <div class="team-row fw-bold" onclick="viewTeamStats('@item.TeamName')" style="cursor: pointer;">
                                                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/21/Flag_of_Vietnam.svg/2000px-Flag_of_Vietnam.svg.png" class="team-icon">
                                                    @item.TeamName <i class="fa-solid fa-circle-info text-info ms-1 small"></i>
                                                </div>
                                                <div class="team-row text-secondary small mt-1">
                                                    @if (item.Status == "Đang chờ đối thủ" || string.IsNullOrEmpty(item.OpponentName))
                                                    {
                                                        <span>Đang chờ đối thủ...</span>
                                                    }
                                                    else
                                                    {
                                                        <img src="https://cdn-icons-png.flaticon.com/512/1165/1165230.png" class="team-icon" style="width:16px;height:16px;">
                                                        <span class="text-primary fw-bold" onclick="viewTeamStats('@item.OpponentName')" style="cursor: pointer;">Đối thủ: @item.OpponentName</span>
                                                        <span class="badge bg-success ms-1">ĐÃ CỌC</span>
                                                    }
                                                </div>
                                            </div>
                                            @if (item.Status == "Đang chờ đối thủ")
                                            {
                                                if (ViewBag.IsMember != null && (bool)ViewBag.IsMember)
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-success fw-bold px-3" onclick="handleAcceptMatch('@item.TeamName', @item.Id)">Nhận Kèo</button>
                                                }
                                                else
                                                {

                                                    <a asp-controller="HoiVien" asp-action="DangKy" class="btn btn-sm btn-outline-secondary fw-bold px-3"><i class="fa-solid fa-lock me-1"></i> Nhận Kèo</a>
                                                }
                                            }
                                            else
                                            {

                                                <button class="btn btn-sm btn-secondary disabled">Đã chốt</button>
                                            }
                                        </div>
                                        <div class="mt-3 pt-3 border-top border-secondary border-opacity-25 small">
                                            <div><i class="fa-regular fa-clock me-1"></i>@item.TimeSlot | <i class="fa-solid fa-location-dot me-1 text-info"></i>@item.PitchName</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="teamStatsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 550px;">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div style="background: #212529; height: 100px; position: relative;">
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" style="z-index: 100;"></button>
            </div>

            <div class="modal-body px-4 pb-5 pt-0 text-center">
                <div style="position: relative; margin-top: -65px; z-index: 50;">
                    <img id="statLogo" src="/images/default-logo.png" alt="Logo"
                         style="width: 130px; height: 130px; object-fit: cover; border-radius: 50% !important; border: 6px solid #fff; box-shadow: 0 5px 15px rgba(0,0,0,0.2); background-color: #fff;">
                </div>

                <h2 class="fw-bold text-uppercase" id="statTeamName" style="margin-top: 20px; margin-bottom: 5px; color: #1a1a1a;">TÊN ĐỘI BÓNG</h2>
                <p class="text-muted fst-italic mb-4" id="statDescription">"Khẩu hiệu đội bóng"</p>

                <div class="row g-3 mb-4">
                    <div class="col-4"><div class="stat-box win"><div class="stat-value" id="statWins">0</div><div class="stat-label">Thắng</div></div></div>
                    <div class="col-4"><div class="stat-box draw"><div class="stat-value" id="statDraws">0</div><div class="stat-label">Hòa</div></div></div>
                    <div class="col-4"><div class="stat-box loss"><div class="stat-value" id="statLosses">0</div><div class="stat-label">Thua</div></div></div>
                </div>

                <div class="card border-0 bg-light rounded-4 p-4 text-start shadow-sm">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="fw-bold small">Tỉ lệ thắng</span>
                        <span class="fw-bold text-primary small" id="statWinRateText">0%</span>
                    </div>
                    <div class="progress mb-4" style="height: 10px; border-radius: 10px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" id="statWinRateBar" style="width: 0%"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fw-bold small">Điểm Uy Tín (FairPlay)</span>
                        <span class="badge rounded-pill px-3 py-2 fs-6 shadow-sm" id="statFairPlay">100 / 100</span>
                    </div>
                    <hr>
                    <span class="fw-bold d-block mb-2 small"><i class="fa-solid fa-users me-2"></i>Đội hình:</span>
                    <div class="p-3 bg-white border rounded-3 text-muted small shadow-sm" id="statMembers">Đang tải...</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="pitchModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header bg-dark text-white"><h5>Sân khả dụng</h5><button type="button" class="btn-close btn-close-white" onclick="pitchModalObj.hide()"></button></div><div class="modal-body"><div id="pitchListContainer" class="list-group"></div></div></div></div></div>
<div class="modal fade" id="paymentModal" tabindex="-1" data-bs-backdrop="static"><div class="modal-dialog modal-dialog-centered"><div class="modal-content text-center p-4"><h3>Tiền cọc: <span id="depositAmount">0 đ</span></h3><img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=COC" class="mx-auto mb-3"><button class="btn btn-success" onclick="confirmPaymentAndPost()">Tôi đã chuyển khoản</button></div></div></div>
<div class="modal fade" id="acceptMatchModal" tabindex="-1" data-bs-backdrop="static"><div class="modal-dialog modal-dialog-centered"><div class="modal-content p-4"><h5>Xác nhận chốt kèo</h5><input type="text" id="acceptorNameInput" class="form-control mb-3 bg-light" value="@ViewBag.MyTeamName" readonly><input type="text" id="acceptorPhoneInput" class="form-control mb-3" value="@currentUser?.PhoneNumber" @(string.IsNullOrEmpty(currentUser?.PhoneNumber) ? "" : "readonly")><button class="btn btn-primary" onclick="confirmAcceptPayment()">Xác nhận chuyển cọc 100k</button></div></div></div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder().withUrl("/matchHub").build();
        let pitchModalObj, paymentModalObj, acceptMatchModalObj, teamStatsModalObj;
        let pendingMatchData = null;

        connection.start().then(() => { document.getElementById("sendButton").disabled = false; });

        async function viewTeamStats(teamName) {
            try {
                const response = await fetch(`/TimDoiThu/GetTeamStats?teamName=${encodeURIComponent(teamName)}`);
                const data = await response.json();
                if (!data.success) { alert(data.message); return; }

                document.getElementById('statTeamName').innerText = data.teamName;
                document.getElementById('statLogo').src = data.logoUrl || "/images/default-logo.png";
                document.getElementById('statDescription').innerText = '"' + (data.description || "Giao lưu học hỏi") + '"';
                document.getElementById('statWins').innerText = data.wins;
                document.getElementById('statDraws').innerText = data.draws;
                document.getElementById('statLosses').innerText = data.losses;
                document.getElementById('statMembers').innerText = data.membersList;
                document.getElementById('statWinRateText').innerText = data.winRate + '%';
                document.getElementById('statWinRateBar').style.width = data.winRate + '%';

                const fp = document.getElementById('statFairPlay');
                fp.innerText = data.fairPlayPoint + " / 100";
                fp.className = "badge rounded-pill px-3 py-2 fs-6 " + (data.fairPlayPoint >= 80 ? "bg-success" : "bg-danger");

                if (!teamStatsModalObj) teamStatsModalObj = new bootstrap.Modal(document.getElementById('teamStatsModal'));
                teamStatsModalObj.show();
            } catch (e) { alert("Lỗi tải thông tin."); }
        }

        // Các hàm xử lý SignalR và Modal phụ giữ nguyên logic nhưng tối giản hóa
        function handleAcceptMatch(p, id) { currentPosterName = p; currentAcceptMatchId = id; acceptMatchModalObj = new bootstrap.Modal(document.getElementById('acceptMatchModal')); acceptMatchModalObj.show(); }
        function confirmAcceptPayment() { connection.invoke("AcceptMatch", currentAcceptMatchId, currentPosterName, document.getElementById("acceptorNameInput").value, document.getElementById("acceptorPhoneInput").value); window.location.reload(); }
        async function checkAvailablePitches() { pitchModalObj = new bootstrap.Modal(document.getElementById('pitchModal')); pitchModalObj.show(); const r = await fetch(`/TimDoiThu/GetPitchesStatus?date=${document.getElementById("dateInput").value}&timeSlot=${document.getElementById("timeSlotInput").value}`); const p = await r.json(); let c = document.getElementById("pitchListContainer"); c.innerHTML = ""; p.forEach(s => { c.innerHTML += `<button class="list-group-item" onclick="selectPitch('${s.name}', '${s.price.toLocaleString()}')">${s.name} - ${s.price.toLocaleString()}đ</button>`; }); }
        function selectPitch(n, p) { document.getElementById("selectedPitchName").innerText = n; document.getElementById("selectedPitchPrice").innerText = p + " đ"; pitchModalObj.hide(); }
        document.getElementById("sendButton").addEventListener("click", () => { pendingMatchData = { user: document.getElementById("teamNameInput").value, date: document.getElementById("dateInput").value, time: document.getElementById("timeSlotInput").value, phone: document.getElementById("phoneInput").value, pitch: document.getElementById("selectedPitchName").innerText }; paymentModalObj = new bootstrap.Modal(document.getElementById('paymentModal')); paymentModalObj.show(); });
        function confirmPaymentAndPost() { connection.invoke("FindOpponent", pendingMatchData.user, pendingMatchData.date, pendingMatchData.time, pendingMatchData.phone, pendingMatchData.pitch, ""); window.location.reload(); }
    </script>
}