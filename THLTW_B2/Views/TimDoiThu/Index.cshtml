@model IEnumerable<THLTW_B2.Models.MatchRequest>

@{
    ViewData["Title"] = "Tìm Đối Thủ Giao Lưu";
}

@section Styles {
    <style>
        #matchBoard {
            background-color: #1e1e1e !important;
            border-radius: 8px;
            height: 550px;
            overflow-y: auto;
        }

        .match-date-header {
            color: #ffffff;
            padding: 15px 20px;
            font-size: 1.1rem;
            border-bottom: 1px solid #333333;
            background-color: #1e1e1e;
            position: sticky;
            top: 0;
            z-index: 5;
        }

        .match-card {
            background-color: #2b2b2b;
            color: #ffffff;
            border: 1px solid #333333;
            padding: 15px 20px;
            margin: 10px;
            border-radius: 8px;
            transition: 0.2s;
        }

            .match-card:hover {
                background-color: #333333;
                transform: translateY(-2px);
                border-color: #0d6efd;
            }

        .team-icon {
            width: 24px;
            height: 18px;
            margin-right: 12px;
            border-radius: 2px;
            object-fit: cover;
        }

        .match-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        @@media (max-width: 768px) {
            .match-grid {
                grid-template-columns: 1fr;
            }
        }

        #matchBoard::-webkit-scrollbar {
            width: 6px;
        }

        #matchBoard::-webkit-scrollbar-track {
            background: #1e1e1e;
        }

        #matchBoard::-webkit-scrollbar-thumb {
            background: #444;
            border-radius: 8px;
        }

        .btn:active {
            transform: scale(0.95);
            transition: 0.1s;
        }
    </style>
}

<div class="container mt-5 mb-5">
    <div class="row mb-4 text-center">
        <div class="col-12">
            <h2 class="fw-bold text-uppercase"><i class="fa-solid fa-futbol text-qlsb-blue me-2"></i>Hệ thống cáp kèo trực tuyến</h2>
            <p class="text-muted">Đăng tin và bắt kèo ngay lập tức (Real-time)</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white fw-bold py-3">
                    <i class="fa-solid fa-pen-to-square me-2 text-qlsb-blue"></i>Tạo Kèo Mới
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Chọn ngày <span class="text-danger">*</span></label>
                        <input type="date" id="dateInput" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Khung giờ sân <span class="text-danger">*</span></label>
                        <select id="timeSlotInput" class="form-select">
                            <option value="">-- Chọn khung giờ --</option>
                            <option value="06:00 - 07:30">06:00 - 07:30</option>
                            <option value="07:30 - 09:00">07:30 - 09:00</option>
                            <option value="16:00 - 17:30">16:00 - 17:30</option>
                            <option value="17:30 - 19:00">17:30 - 19:00</option>
                            <option value="19:00 - 20:30">19:00 - 20:30</option>
                            <option value="20:30 - 22:00">20:30 - 22:00</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên đội <span class="text-danger">*</span></label>
                        <input type="text" id="teamNameInput" class="form-control" placeholder="VD: FC HUTECH">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Số điện thoại <span class="text-danger">*</span></label>
                        <input type="text" id="phoneInput" class="form-control" placeholder="09xxxxxxxx">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ghi chú</label>
                        <textarea id="messageInput" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="alert mb-4 py-2" style="background-color: #d1e7dd; border: 1px solid #badbcc; color: #0f5132;">
                        <strong id="selectedPitchName">Chưa chọn sân</strong><br>
                        <span class="fw-bold text-dark fs-5" id="selectedPitchPrice">0 đ</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-info text-white fw-bold" onclick="checkAvailablePitches()">Chọn Sân</button>
                        <button id="sendButton" class="btn btn-primary fw-bold px-4">Đăng Kèo</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white fw-bold py-3">
                    <i class="fa-solid fa-tower-broadcast me-2 text-qlsb-blue"></i>Bảng Tin Trực Tuyến
                </div>
                <div class="card-body p-0" id="matchBoard">
                    @if (Model != null && Model.Any())
                    {
                        var groupedMatches = Model.GroupBy(m => m.MatchDate.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN")));

                        foreach (var group in groupedMatches)
                        {
                            <div class="match-date-header">@group.Key</div>
                            <div class="match-grid" id="grid-@group.Key.Replace(" ", "").Replace(",", "").Replace("/", "")">

                                @foreach (var item in group)
                                {
                                    <div class="match-card">
                                        <div class="match-header-info">
                                            <span>Đăng lúc: @item.CreatedAt.ToString("HH:mm")</span>
                                            <span class="text-warning fw-semibold">Giao hữu</span>
                                        </div>

                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div>
                                                <div class="team-row fw-bold">
                                                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/21/Flag_of_Vietnam.svg/2000px-Flag_of_Vietnam.svg.png" class="team-icon">
                                                    @item.TeamName
                                                </div>

                                                <div class="team-row text-secondary small mt-1">
                                                    @if (item.Status == "Đang chờ đối thủ" || string.IsNullOrEmpty(item.OpponentName))
                                                    {
                                                        <span>Đang chờ đối thủ...</span>
                                                    }
                                                    else
                                                    {
                                                        <img src="https://cdn-icons-png.flaticon.com/512/1165/1165230.png" class="team-icon" style="width:16px;height:16px;">
                                                        <span class="text-primary fw-bold">Đối thủ: @item.OpponentName - @item.OpponentPhone</span>
                                                        <span class="badge bg-success ms-1" style="font-size: 0.65rem;">ĐÃ CỌC</span>
                                                    }
                                                </div>
                                            </div>

                                            @if (item.Status == "Đang chờ đối thủ")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-success fw-bold px-3" onclick="handleAcceptMatch('@item.TeamName', @item.Id)">
                                                    Nhận Kèo
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-secondary disabled">Đã có đối thủ</button>
                                            }
                                        </div>

                                        <div class="mt-3 pt-3 border-top border-secondary border-opacity-25">
                                            <div class="d-flex justify-content-between mb-1 small">
                                                <span class="text-light fw-bold"><i class="fa-regular fa-calendar me-1"></i>@item.MatchDate.ToString("dd/MM/yyyy")</span>
                                                <span class="text-warning fw-bold"><i class="fa-regular fa-clock me-1"></i>@item.TimeSlot</span>
                                            </div>
                                            <div class="text-white small mb-1"><i class="fa-solid fa-location-dot me-2 text-info"></i>Địa điểm: @item.PitchName</div>
                                            <div class="text-white small"><i class="fa-solid fa-phone me-2 text-secondary"></i>@item.Phone | @(string.IsNullOrEmpty(item.Note) ? "N/A" : item.Note)</div>
                                            <div class="mt-2"><span class="badge bg-success" style="font-size: 0.7rem;">ĐÃ CỌC SÂN</span></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted mt-5" id="emptyMessage">
                            <i class="fa-regular fa-comments fa-4x mb-3" style="color: #444;"></i>
                            <h5 class="fw-semibold">Chưa có yêu cầu nào</h5>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="pitchModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold">Sân trống khả dụng</h5>
                <button type="button" class="btn-close btn-close-white" onclick="pitchModalObj.hide()"></button>
            </div>
            <div class="modal-body bg-light">
                <p class="text-muted small">Thời gian: <strong id="modalTimeInfo"></strong></p>
                <div id="pitchListContainer" class="list-group"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="paymentModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-credit-card me-2"></i>Thanh toán tiền cọc</h5>
                <button type="button" class="btn-close btn-close-white" onclick="paymentModalObj.hide()"></button>
            </div>
            <div class="modal-body text-center p-4">
                <p class="mb-2">Vui lòng thanh toán tiền cọc (30%) để xác nhận đăng kèo:</p>
                <h3 class="text-danger fw-bold mb-3" id="depositAmount">0 đ</h3>
                <div class="bg-light p-3 rounded mb-3 border">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=ThanhToanCocQLSB" alt="QR" class="img-fluid shadow-sm mb-2">
                    <p class="small text-muted mb-0">Nội dung: <strong id="paymentContent"></strong></p>
                </div>
                <div class="alert alert-warning py-2 small mb-0 text-start">
                    <i class="fa-solid fa-circle-info me-1"></i> Kèo sẽ được đăng ngay sau khi bạn xác nhận "Tôi đã chuyển khoản".
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-center border-0 pb-4">
                <button type="button" class="btn btn-secondary px-4 me-2" onclick="paymentModalObj.hide()">Hủy bỏ</button>
                <button type="button" class="btn btn-success px-4 fw-bold" onclick="confirmPaymentAndPost()">
                    <i class="fa-solid fa-check-circle me-1"></i>Tôi đã chuyển khoản
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="acceptMatchModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-handshake me-2"></i>Xác nhận Nhận Kèo</h5>
                <button type="button" class="btn-close btn-close-white" onclick="acceptMatchModalObj.hide()"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3 text-start">
                    <label class="form-label fw-semibold">Tên đội của bạn <span class="text-danger">*</span></label>
                    <input type="text" id="acceptorNameInput" class="form-control" placeholder="VD: FC Sinh Viên">
                </div>
                <div class="mb-3 text-start">
                    <label class="form-label fw-semibold">Số điện thoại liên hệ <span class="text-danger">*</span></label>
                    <input type="text" id="acceptorPhoneInput" class="form-control" placeholder="09xxxxxxxx">
                </div>
                <hr>
                <div class="text-center mt-3">
                    <p class="mb-2">Vui lòng thanh toán cọc để chốt kèo với đội <strong id="modalPosterName" class="text-primary"></strong>:</p>
                    <h3 class="text-danger fw-bold mb-3">100,000 đ</h3>
                    <div class="bg-light p-3 rounded mb-3 border">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=ThanhToanCocNhanKeo" alt="QR" class="img-fluid shadow-sm mb-2">
                        <p class="small text-muted mb-0">Nội dung CK: <strong id="acceptPaymentContent"></strong></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-center border-0 pb-4">
                <button type="button" class="btn btn-secondary px-4 me-2" onclick="acceptMatchModalObj.hide()">Hủy bỏ</button>
                <button type="button" class="btn btn-success px-4 fw-bold" onclick="confirmAcceptPayment()">
                    <i class="fa-solid fa-check-circle me-1"></i>Tôi đã chuyển khoản
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder().withUrl("/matchHub").build();
        let pitchModalObj, paymentModalObj, acceptMatchModalObj;
        let pendingMatchData = null;
        let currentAcceptMatchId = null;
        let currentPosterName = null;

        // 1. NHẬN KÈO MỚI TẠO (REAL-TIME)
        connection.on("ReceiveOpponentRequest", function (user, message) {
            const emptyMsg = document.getElementById("emptyMessage");
            if(emptyMsg) emptyMsg.style.display = 'none';

            const board = document.getElementById("matchBoard");
            const now = new Date();
            const timeString = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            const dateString = now.toLocaleDateString('vi-VN', { weekday: 'long', month: 'numeric', day: 'numeric', year: 'numeric' });

            let gridId = "grid-" + dateString.replace(/[\s,\/]/g, '');
            let targetGrid = document.getElementById(gridId);

            if (!targetGrid) {
                const header = document.createElement("div");
                header.className = "match-date-header";
                header.innerText = dateString;
                board.insertBefore(header, board.firstChild);
                targetGrid = document.createElement("div");
                targetGrid.id = gridId;
                targetGrid.className = "match-grid";
                board.insertBefore(targetGrid, header.nextSibling);
            }

            const matchCard = document.createElement("div");
            matchCard.className = "match-card";
            matchCard.innerHTML = `
                <div class="match-header-info"><span>Đăng lúc: ${timeString}</span><span class="text-warning fw-semibold">Giao hữu</span></div>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <div class="team-row fw-bold"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/21/Flag_of_Vietnam.svg/2000px-Flag_of_Vietnam.svg.png" class="team-icon">${user}</div>
                        <div class="team-row text-secondary small mt-1">Đang chờ đối thủ...</div>
                    </div>
                    <button class="btn btn-sm btn-outline-success fw-bold px-3" onclick="alert('Vui lòng làm mới trang (F5) để nhận kèo mới đăng này!')">Nhận Kèo</button>
                </div>
                <div class="mt-3 pt-3 border-top border-secondary border-opacity-25">${message}</div>
            `;
            targetGrid.insertBefore(matchCard, targetGrid.firstChild);
        });

        // 2. CẬP NHẬT TRẠNG THÁI NHẬN KÈO (REAL-TIME)
        connection.on("MatchAcceptedUpdate", function (posterName, acceptorName, acceptorPhone) {
            const cards = document.querySelectorAll('.match-card');
            cards.forEach(card => {
                if (card.querySelector('.team-row.fw-bold').innerText.includes(posterName)) {
                    const opponentRow = card.querySelector('.team-row.text-secondary');

                    // Hiển thị SĐT và Huy hiệu ĐÃ CỌC
                    opponentRow.innerHTML = `
                        <img src="https://cdn-icons-png.flaticon.com/512/1165/1165230.png" class="team-icon" style="width:16px;height:16px;">
                        <span class="text-primary fw-bold">Đối thủ: ${acceptorName} - ${acceptorPhone}</span>
                        <span class="badge bg-success ms-1" style="font-size: 0.65rem;">ĐÃ CỌC</span>
                    `;

                    const btn = card.querySelector('button');
                    if (btn) { btn.className = "btn btn-sm btn-secondary disabled"; btn.innerText = "Đã có đối thủ"; btn.onclick = null; }
                    card.style.border = "1px solid #0d6efd";
                }
            });
        });

        connection.start().then(() => {
            document.getElementById("sendButton").disabled = false;
        }).catch(err => console.error(err));

        // 3. XỬ LÝ NÚT NHẬN KÈO
        function handleAcceptMatch(posterName, matchId) {
            currentPosterName = posterName;
            currentAcceptMatchId = matchId;

            document.getElementById("acceptorNameInput").value = "";
            document.getElementById("acceptorPhoneInput").value = "";
            document.getElementById("modalPosterName").innerText = posterName;
            document.getElementById("acceptPaymentContent").innerText = "NHAN KEO " + matchId;

            acceptMatchModalObj = new bootstrap.Modal(document.getElementById('acceptMatchModal'));
            acceptMatchModalObj.show();
        }

        // 4. XÁC NHẬN CHUYỂN KHOẢN (NHẬN KÈO)
        function confirmAcceptPayment() {
            const acceptorName = document.getElementById("acceptorNameInput").value;
            const acceptorPhone = document.getElementById("acceptorPhoneInput").value;

            if (!acceptorName || !acceptorPhone) {
                alert("Vui lòng nhập đầy đủ Tên đội và Số điện thoại!");
                return;
            }

            connection.invoke("AcceptMatch", currentAcceptMatchId, currentPosterName, acceptorName.trim(), acceptorPhone.trim())
                .catch(err => console.error(err));

            acceptMatchModalObj.hide();
            alert("Thanh toán thành công! Bạn đã chốt kèo với " + currentPosterName + ".");
        }

        // CÁC HÀM XỬ LÝ TẠO KÈO
        async function checkAvailablePitches() {
            const date = document.getElementById("dateInput").value;
            const time = document.getElementById("timeSlotInput").value;
            if (!date || !time) return alert("Vui lòng chọn Ngày và Khung giờ!");

            document.getElementById("modalTimeInfo").innerText = `${date} | ${time}`;
            const container = document.getElementById("pitchListContainer");

            // Hiển thị vòng xoay đang tải
            container.innerHTML = `<div class="text-center text-muted my-4"><i class="fa-solid fa-spinner fa-spin fa-2x mb-2"></i><br>Đang tải danh sách sân...</div>`;

            if (!pitchModalObj) pitchModalObj = new bootstrap.Modal(document.getElementById('pitchModal'));
            pitchModalObj.show();

            try {
                // Gọi API
                const response = await fetch(`/TimDoiThu/GetPitchesStatus?date=${date}&timeSlot=${time}`);
                const pitches = await response.json();

                container.innerHTML = "";

                if (pitches.length === 0) {
                    container.innerHTML = `<div class="alert alert-warning">Hiện chưa có sân nào trên hệ thống. Admin cần thêm sân mới!</div>`;
                    return;
                }

                // Duyệt qua dữ liệu thật từ DB
                pitches.forEach(pitch => {
                    // Format tiền tệ VNĐ (VD: 300000 -> 300.000)
                    const formattedPrice = pitch.price.toLocaleString('vi-VN');

                    // Nếu sân đã bị đặt -> KHÓA NÚT MÀU XÁM
                    if (pitch.isBooked) {
                        container.innerHTML += `
                            <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center mb-2 rounded border bg-light text-muted" disabled style="cursor: not-allowed;">
                                <span><del class="fw-bold">${pitch.name}</del> <span class="small text-danger ms-1">(Đã hết chỗ)</span></span>
                                <span class="badge bg-secondary">${formattedPrice} đ</span>
                            </button>`;
                    }
                    // Nếu sân trống -> NÚT XANH BẤM ĐƯỢC
                    else {
                        container.innerHTML += `
                            <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center mb-2 rounded border shadow-sm" onclick="selectPitch('${pitch.name}', '${formattedPrice}')">
                                <span class="fw-bold text-primary">${pitch.name}</span>
                                <span class="badge bg-success" style="font-size: 0.9rem;">${formattedPrice} đ</span>
                            </button>`;
                    }
                });
            } catch (error) {
                console.error("Lỗi khi tải sân:", error);
                container.innerHTML = `<div class="alert alert-danger">Lỗi kết nối! Không thể lấy dữ liệu sân.</div>`;
            }
        }

        function selectPitch(name, price) {
            document.getElementById("selectedPitchName").innerText = "Đã chọn: " + name;
            document.getElementById("selectedPitchPrice").innerText = price + " đ";
            pitchModalObj.hide();
        }

        document.getElementById("sendButton").addEventListener("click", function (e) {
            e.preventDefault();
            const user = document.getElementById("teamNameInput").value;
            const date = document.getElementById("dateInput").value;
            const time = document.getElementById("timeSlotInput").value;
            const phone = document.getElementById("phoneInput").value;
            const pitchName = document.getElementById("selectedPitchName").innerText.replace("Đã chọn: ", "");

            if (!user || !date || !time || !phone || pitchName === "Chưa chọn sân") return alert("Vui lòng điền đủ thông tin và chọn sân!");

            pendingMatchData = { user, date, time, phone, note: document.getElementById("messageInput").value, pitch: pitchName };

            // VÁ LỖI TÍNH TIỀN 90 ĐỒNG Ở ĐÂY: Dùng regex \D để xóa mọi ký tự không phải số trước khi tính
            const priceText = document.getElementById("selectedPitchPrice").innerText;
            const priceNumber = parseInt(priceText.replace(/\D/g, ''));
            const deposit = priceNumber * 0.3;

            document.getElementById("depositAmount").innerText = deposit.toLocaleString('vi-VN') + " đ";
            document.getElementById("paymentContent").innerText = "COC " + user.toUpperCase().replace(/\s/g, '');

            paymentModalObj = new bootstrap.Modal(document.getElementById('paymentModal'));
            paymentModalObj.show();
        });

        function confirmPaymentAndPost() {
            if (!pendingMatchData) return;
            const { user, date, time, phone, note, pitch } = pendingMatchData;

            connection.invoke("FindOpponent", user, date, time, phone, pitch, note || "").catch(err => console.error(err));

            paymentModalObj.hide();
            document.getElementById("messageInput").value = "";
            alert("Thanh toán thành công! Kèo của bạn đang được đăng tải.");
        }
    </script>
}