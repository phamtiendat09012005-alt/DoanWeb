@using Microsoft.AspNetCore.Identity
@inject UserManager<THLTW_B2.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Đặt Sân Bóng Bao Trọn";
    // LẤY THÔNG TIN VIP TỪ SERVER
    var currentUser = await UserManager.GetUserAsync(User);
    bool isVip = currentUser != null && currentUser.IsVip && currentUser.VipExpirationDate > DateTime.Now;
}

@section Styles {
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css' rel='stylesheet' />
    <style>
        .pitch-card {
            transition: 0.2s;
        }

            .pitch-card:hover {
                box-shadow: 0 4px 8px rgba(0,0,0,0.1);
                transform: translateY(-2px);
            }

        #calendar {
            background-color: white;
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 0 15px rgba(0,0,0,0.05);
            height: 100%;
        }

        .fc-event {
            cursor: pointer;
            border: none;
            padding: 2px 4px;
            font-weight: 500;
        }

        .fc-daygrid-day:hover {
            background-color: #f8f9fa;
            cursor: pointer;
        }
    </style>
}

<div class="container-fluid px-5 mt-4 mb-5">
    <div class="row mb-3 text-center">
        <div class="col-12">
            <h2 class="fw-bold text-uppercase"><i class="fa-solid fa-calendar-check text-primary me-2"></i>Hệ thống Đặt Sân Trực Tuyến</h2>
            <p class="text-muted">Bao trọn sân, giữ giờ ngay lập tức</p>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="row justify-content-center mb-3">
            <div class="col-md-8 text-center alert alert-success shadow-sm fw-bold">
                <i class="fa-solid fa-circle-check me-2"></i>@TempData["Message"]
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="row justify-content-center mb-3">
            <div class="col-md-8 text-center alert alert-danger shadow-sm fw-bold">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["Error"]
            </div>
        </div>
    }

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-dark text-white fw-bold py-3">
                    <i class="fa-solid fa-pen-to-square me-2 text-info"></i>Thông Tin Đặt Sân
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-info py-2 small mb-3">
                        <i class="fa-solid fa-hand-pointer me-1"></i> Mẹo: Bạn có thể bấm vào lịch bên cạnh để chọn ngày nhanh!
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Chọn ngày <span class="text-danger">*</span></label>
                        <input type="date" id="dateInput" class="form-control" onchange="autoLoadPitches()">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Khung giờ sân <span class="text-danger">*</span></label>
                        <select id="timeSlotInput" class="form-select" onchange="autoLoadPitches()">
                            <option value="">-- Chọn khung giờ --</option>
                            <option value="06:00 - 07:30">06:00 - 07:30 (Sáng sớm)</option>
                            <option value="07:30 - 09:00">07:30 - 09:00</option>
                            <option value="09:00 - 10:30">09:00 - 10:30</option>
                            <option value="10:30 - 12:00">10:30 - 12:00</option>

                            <option value="14:30 - 16:00">14:30 - 16:00</option>
                            <option value="16:00 - 17:30">16:00 - 17:30</option>

                            <option value="17:30 - 19:00 (Giờ vàng)">17:30 - 19:00 (Giờ vàng)</option>
                            <option value="19:00 - 20:30 (Giờ vàng)">19:00 - 20:30 (Giờ vàng)</option>
                            <option value="20:30 - 22:00 (Giờ vàng)">20:30 - 22:00 (Giờ vàng)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Họ và Tên <span class="text-danger">*</span></label>
                        <input type="text" id="nameInput" class="form-control" placeholder="VD: Nguyễn Văn A" value="@(currentUser?.FullName ?? currentUser?.UserName)">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Số điện thoại <span class="text-danger">*</span></label>
                        <input type="text" id="phoneInput" class="form-control" placeholder="09xxxxxxxx" value="@currentUser?.PhoneNumber">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ghi chú thêm</label>
                        <textarea id="noteInput" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="alert mb-4 py-2" style="background-color: #d1e7dd; border: 1px solid #badbcc; color: #0f5132;">
                        <strong id="selectedPitchName">Chưa chọn sân</strong><br>
                        <span class="fw-bold text-dark fs-5" id="selectedPitchPriceDisplay">0 đ</span>
                        <input type="hidden" id="hiddenPitchId" value="" />
                        <input type="hidden" id="hiddenPitchPrice" value="0" />
                    </div>

                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-info text-white fw-bold" onclick="checkAvailablePitches()">Chọn Sân</button>
                        <button id="btnXacNhan" class="btn btn-primary fw-bold px-4">
                            @(isVip ? "Xác Nhận Đặt" : "Thanh Toán VNPay")
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="pitchModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold">Sân trống khả dụng</h5>
                <button type="button" class="btn-close btn-close-white" onclick="pitchModalObj.hide()"></button>
            </div>
            <div class="modal-body bg-light">
                <p class="text-muted small">Thời gian: <strong id="modalTimeInfo" class="text-primary"></strong></p>
                <div id="pitchListContainer" class="list-group"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js'></script>
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales/vi.js'></script>

    <script>
        const isVipUser = @isVip.ToString().ToLower();
        let pitchModalObj, pendingBookingData = null;

        document.addEventListener('DOMContentLoaded', function() {
            let dateInputElem = document.getElementById("dateInput");
            if (dateInputElem) {
                let today = new Date();
                let tzoffset = today.getTimezoneOffset() * 60000;
                let localISOTime = (new Date(today - tzoffset)).toISOString().slice(0, 10);
                dateInputElem.setAttribute('min', localISOTime);
            }

            var calendarEl = document.getElementById('calendar');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'timeGridWeek',
                locale: 'vi',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,listWeek'
                },
                slotMinTime: '06:00:00',
                slotMaxTime: '23:00:00',
                events: '/DatSan/GetCalendarEvents',
                dateClick: function(info) {
                    const selectedDate = info.dateStr.split('T')[0];
                    let today = new Date();
                    today.setHours(0,0,0,0);
                    let clickedDate = new Date(selectedDate);

                    if(clickedDate < today) {
                        alert("Không thể chọn ngày trong quá khứ sếp ơi!");
                        return;
                    }

                    document.getElementById('dateInput').value = selectedDate;
                    const dateInput = document.getElementById('dateInput');
                    dateInput.style.boxShadow = "0 0 10px #0d6efd";
                    setTimeout(() => dateInput.style.boxShadow = "none", 800);

                    autoLoadPitches();
                }
            });
            calendar.render();
        });

        function autoLoadPitches() {
            const time = document.getElementById("timeSlotInput").value;
            const date = document.getElementById("dateInput").value;
            if (date && time) checkAvailablePitches();
        }

        function tinhSoGioDa(khungGio) {
            try {
                let gio = khungGio.split('-');
                let batDau = gio[0].trim().split(':');
                let ketThuc = gio[1].trim().split(':');
                let phutBatDau = parseInt(batDau[0]) * 60 + parseInt(batDau[1]);
                let phutKetThuc = parseInt(ketThuc[0]) * 60 + parseInt(ketThuc[1]);
                return (phutKetThuc - phutBatDau) / 60;
            } catch (e) {
                return 1.5;
            }
        }

        async function checkAvailablePitches() {
            const date = document.getElementById("dateInput").value;
            const time = document.getElementById("timeSlotInput").value;
            if (!date || !time) return alert("Vui lòng chọn Ngày và Khung giờ!");

            // BẢO VỆ GIỜ VÀNG
            if (time.includes("Giờ vàng") && !isVipUser) {
                alert("👑 ĐẶC QUYỀN VIP: Khung Giờ Vàng (17:30 - 22:00) đang rất khan hiếm và chỉ dành riêng cho Hội Viên VIP. Vui lòng nâng cấp tài khoản để đặt sân!");
                document.getElementById("timeSlotInput").value = "";
                return;
            }

            let startTimeStr = time.split('-')[0].trim();
            let [hours, minutes] = startTimeStr.split(':');
            let selectedDateTime = new Date(date);
            selectedDateTime.setHours(parseInt(hours), parseInt(minutes), 0, 0);
            let now = new Date();

            if (selectedDateTime <= now) {
                document.getElementById("timeSlotInput").value = "";
                document.getElementById("selectedPitchName").innerText = "Chưa chọn sân";
                document.getElementById("selectedPitchPriceDisplay").innerText = "0 đ";
                document.getElementById("hiddenPitchId").value = "";
                return alert("Ca đá này đã trôi qua rồi sếp ơi! Vui lòng chọn khung giờ khác.");
            }

            document.getElementById("modalTimeInfo").innerText = `${date} | ${time}`;
            const container = document.getElementById("pitchListContainer");
            container.innerHTML = `<div class="text-center text-muted my-4"><i class="fa-solid fa-spinner fa-spin fa-2x mb-2"></i><br>Đang tải...</div>`;

            if (!pitchModalObj) pitchModalObj = new bootstrap.Modal(document.getElementById('pitchModal'));
            pitchModalObj.show();

            try {
                const soGioDa = tinhSoGioDa(time);
                const response = await fetch(`/DatSan/GetAvailablePitches?date=${date}&timeSlot=${time}`);
                const pitches = await response.json();
                container.innerHTML = "";

                if (pitches.length === 0) {
                    container.innerHTML = `<div class="alert alert-warning">Chưa có dữ liệu sân.</div>`; return;
                }

                pitches.forEach(pitch => {
                    let tongTienSan = pitch.price * soGioDa;
                    if (pitch.isBooked) {
                        container.innerHTML += `
                            <div class="list-group-item d-flex justify-content-between mb-2 rounded border bg-light text-muted" style="cursor: not-allowed;">
                                <span><del class="fw-bold">${pitch.name}</del> <span class="small text-danger ms-1">(Đã hết chỗ)</span></span>
                                <span class="badge bg-secondary">${tongTienSan.toLocaleString('vi-VN')} đ</span>
                            </div>`;
                    } else {
                        container.innerHTML += `
                            <label class="list-group-item d-flex justify-content-between align-items-center mb-2 rounded border shadow-sm" style="cursor: pointer;">
                                <div class="text-start form-check mb-0">
                                    <input class="form-check-input pitch-checkbox fs-5" type="checkbox" value="${pitch.id}" data-name="${pitch.name}" data-price="${tongTienSan}">
                                    <span class="fw-bold text-primary ms-2">${pitch.name}</span><br>
                                    <small class="text-muted ms-4">${pitch.price.toLocaleString('vi-VN')}đ/h x ${soGioDa} giờ</small>
                                </div>
                                <span class="badge bg-success" style="font-size: 0.9rem;">+ ${tongTienSan.toLocaleString('vi-VN')} đ</span>
                            </label>`;
                    }
                });

                container.innerHTML += `<button class="btn btn-primary w-100 fw-bold mt-2 py-2 shadow" onclick="confirmMultiplePitches()"><i class="fa-solid fa-check-double me-2"></i>Xác Nhận Sân Đã Chọn</button>`;

            } catch (error) {
                container.innerHTML = `<div class="alert alert-danger">Lỗi kết nối máy chủ!</div>`;
            }
        }

        function confirmMultiplePitches() {
            let checkedBoxes = document.querySelectorAll('.pitch-checkbox:checked');
            if(checkedBoxes.length === 0) return alert("Vui lòng tích chọn ít nhất 1 sân để bao trọn!");

            let ids = [];
            let names = [];
            let total = 0;

            checkedBoxes.forEach(cb => {
                ids.push(cb.value);
                names.push(cb.getAttribute('data-name'));
                total += parseFloat(cb.getAttribute('data-price'));
            });

            document.getElementById("selectedPitchName").innerHTML = `Đã bao trọn <b class="text-danger">${checkedBoxes.length} sân</b>: <br/> <span class="text-primary">${names.join(", ")}</span>`;
            document.getElementById("selectedPitchPriceDisplay").innerText = "Tổng tiền: " + total.toLocaleString('vi-VN') + " đ";

            document.getElementById("hiddenPitchId").value = ids.join(",");
            document.getElementById("hiddenPitchPrice").value = total;

            pitchModalObj.hide();
        }

        // BẮT SỰ KIỆN THANH TOÁN
        document.getElementById("btnXacNhan").addEventListener("click", function (e) {
            e.preventDefault();
            const name = document.getElementById("nameInput").value;
            const date = document.getElementById("dateInput").value;
            const time = document.getElementById("timeSlotInput").value;
            const phone = document.getElementById("phoneInput").value;
            const pitchIds = document.getElementById("hiddenPitchId").value;
            const tongTien = document.getElementById("hiddenPitchPrice").value;

            if (!name || !date || !time || !phone || !pitchIds) return alert("Vui lòng điền đủ thông tin và chọn ít nhất 1 sân!");

            pendingBookingData = { pitchIds, date, time, price: tongTien, note: document.getElementById("noteInput").value };

            if (isVipUser) {
                if (confirm("👑 ĐẶC QUYỀN VIP: Bạn được miễn phí tiền cọc, giữ sân 100% và thanh toán khi đến sân. Chốt đặt ngay?")) {
                    processBooking();
                }
            } else {
                // CHẠY THẲNG VÀO HÀM XỬ LÝ VNPAY
                processBooking();
            }
        });

        // GỌI XUỐNG BACKEND ĐỂ LẤY LINK VNPAY HOẶC LƯU VIP
        async function processBooking() {
            if (!pendingBookingData) return;
            const formData = new FormData();
            formData.append('soccerFieldIds', pendingBookingData.pitchIds);
            formData.append('date', pendingBookingData.date);
            formData.append('timeSlot', pendingBookingData.time);
            formData.append('price', pendingBookingData.price);
            formData.append('note', pendingBookingData.note);

            const btn = document.getElementById("btnXacNhan");
            const originalHtml = btn.innerHTML;
            btn.innerHTML = `<span class="spinner-border spinner-border-sm me-1"></span> Đang xử lý...`;
            btn.disabled = true;

            try {
                const response = await fetch('/DatSan/TaoDonDatSan', { method: 'POST', body: formData });
                const result = await response.json();

                if (result.success) {
                    if (result.isVip) {
                        alert("👑 ĐẶC QUYỀN VIP: Đã giữ chỗ thành công!");
                        window.location.reload();
                    } else {
                        // Nhảy sang trang quét thẻ của VNPay
                        window.location.href = result.url;
                    }
                } else {
                    alert("Lỗi: " + result.message);
                    btn.innerHTML = originalHtml;
                    btn.disabled = false;
                }
            } catch (err) {
                alert("Lỗi kết nối mạng!");
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        }
    </script>
}