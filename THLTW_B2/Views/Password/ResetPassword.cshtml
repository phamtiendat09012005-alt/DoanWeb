@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Đặt lại mật khẩu - QLSBMini</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow">
                    <div class="card-body p-4">
                        <h3 class="text-center text-primary mb-3">Tạo Mật Khẩu Mới</h3>
                        <p class="text-muted text-center">Chúng tôi đã gửi mã OTP đến <b>@ViewBag.Email</b>. Vui lòng kiểm tra hộp thư.</p>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger text-center">@ViewBag.Error</div>
                        }

                        <form method="post" action="/Password/ResetPassword">
                            <input type="hidden" name="email" value="@ViewBag.Email" />

                            <div class="form-floating mb-3">
                                <input type="text" name="otp" class="form-control" placeholder="123456" required autocomplete="off" />
                                <label>Nhập mã OTP 6 số</label>
                            </div>

                            <div class="form-floating mb-3">
                                <input type="password" name="newPassword" class="form-control" placeholder="Mật khẩu mới" required />
                                <label>Mật khẩu mới</label>
                            </div>

                            <div class="form-floating mb-3">
                                <input type="password" name="confirmPassword" class="form-control" placeholder="Xác nhận mật khẩu" required />
                                <label>Xác nhận mật khẩu mới</label>
                            </div>

                            <button type="submit" class="w-100 btn btn-lg btn-success">Xác nhận đổi mật khẩu</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>