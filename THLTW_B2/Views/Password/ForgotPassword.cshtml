@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Quên mật khẩu - QLSBMini</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow">
                    <div class="card-body p-4">
                        <h3 class="text-center text-primary mb-4">Khôi Phục Mật Khẩu</h3>
                        <p class="text-muted text-center">Nhập email bạn đã đăng ký, chúng tôi sẽ gửi 1 mã gồm 6 chữ số để bạn lấy lại mật khẩu.</p>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger text-center">@ViewBag.Error</div>
                        }

                        <form method="post" action="/Password/ForgotPassword">
                            <div class="form-floating mb-3">
                                <input type="email" name="email" class="form-control" placeholder="name@example.com" required />
                                <label>Nhập Email của bạn</label>
                            </div>
                            <button type="submit" class="w-100 btn btn-lg btn-primary">Gửi mã xác nhận OTP</button>
                        </form>

                        <div class="text-center mt-3">
                            <a href="/Identity/Account/Login">Quay lại Đăng nhập</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>