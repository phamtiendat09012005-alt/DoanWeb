@model IEnumerable<THLTW_B2.Models.Product>
@{
    Layout = "~/Areas/Employee/Views/Shared/_EmployeeLayout.cshtml";
    ViewData["Title"] = "Bán hàng tại quầy";
}

<style>
    .dashboard-wrapper {
        margin-left: 260px;
        width: calc(100% - 260px);
        padding: 20px;
        background-color: #f4f6f9;
        min-height: 100vh;
    }

    @@media (max-width: 991.98px) {
        .dashboard-wrapper {
            margin-left: 0;
            width: 100%;
            padding: 15px;
        }
    }

    .container-fluid {
        width: 100%;
        max-width: 100%;
        padding: 0;
    }

    .pos-product-card {
        cursor: pointer;
        transition: transform 0.1s ease, box-shadow 0.1s ease;
        border: 2px solid transparent;
        background: #fff;
    }

        .pos-product-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
            border-color: #198754;
        }

    .product-icon-wrap {
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #e9ecef;
        border-radius: 8px 8px 0 0;
        font-size: 2rem;
        color: #6c757d;
    }

    .bill-area {
        background: white;
        border-radius: 12px;
        box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
        height: calc(100vh - 60px);
        display: flex;
        flex-direction: column;
        position: sticky;
        top: 20px;
    }

    .bill-items {
        flex-grow: 1;
        overflow-y: auto;
        padding-right: 5px;
    }
</style>

<div class="dashboard-wrapper">
    <div class="container-fluid mt-2">
        <div class="row g-4">

            <div class="col-lg-8">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold text-dark mb-0"><i class="fa-solid fa-store me-2 text-success"></i>Bán hàng & Dịch vụ</h4>

                    <div class="btn-group shadow-sm" id="category-filters">
                        <button class="btn btn-success fw-bold filter-btn" onclick="locSanPham('Tất cả', this)">Tất cả</button>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in ViewBag.Categories)
                            {
                                <button class="btn btn-outline-success bg-white filter-btn" onclick="locSanPham('@cat.CategoryId', this)">@cat.Name</button>
                            }
                        }
                    </div>
                </div>

                <div class="row g-3">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <div class="col-6 col-md-4 col-xl-3 product-item" data-category="@item.CategoryId">
                                <div class="card h-100 border-0 shadow-sm pos-product-card rounded-3"
                                     onclick="addToCart(@item.ProductId, '@item.Name', @((long)item.Price), @item.StockQuantity)">

                                    <div class="product-icon-wrap position-relative" style="background: #fff; padding: 5px;">
                                        @* SỬ DỤNG THẺ IMG ĐỂ LẤY ẢNH TỪ KHO *@
                                        @* Lưu ý: Sửa 'ImageUrl' thành đúng tên thuộc tính lưu ảnh trong file Product.cs của bạn (VD: Image, HinhAnh, Avatar...) *@
                                        <img src="@item.ImageUrl" alt="@item.Name" class="w-100 h-100" style="object-fit: contain; border-radius: 8px 8px 0 0;"
                                             onerror="this.src='https://via.placeholder.com/150?text=No+Image'" />

                                        <span class="position-absolute top-0 end-0 badge bg-danger m-2 shadow-sm" style="font-size: 14px;">Tồn: @item.StockQuantity</span>
                                    </div>

                                    <div class="card-body text-center p-2">
                                        <h6 class="fw-bold mb-1 text-dark">@item.Name</h6>
                                        <div class="text-success fw-bold">@item.Price.ToString("N0") đ</div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center text-muted mt-5 pt-5">
                            <i class="fa-solid fa-box-archive fa-4x mb-3 opacity-25"></i>
                            <h5 class="fw-bold">Kho hàng đang trống</h5>
                            <p>Vui lòng thêm sản phẩm/dịch vụ vào Database để bắt đầu bán hàng.</p>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="bill-area p-3">
                    <h5 class="fw-bold border-bottom pb-2 mb-3"><i class="fa-solid fa-file-invoice-dollar me-2 text-primary"></i>Hóa đơn hiện tại</h5>

                    <div class="mb-3">
                        <select class="form-select bg-light border-0 shadow-sm fw-bold text-dark">
                            <option>-- Khách lẻ (Mua mang đi) --</option>
                            <option>Gắn vào Sân 1 (Đang đá)</option>
                            <option>Gắn vào Sân 2 (Đang đá)</option>
                        </select>
                    </div>

                    <div class="bill-items mb-3">
                    </div>

                    <div class="border-top pt-3 mt-auto">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted fw-bold">Tổng số lượng:</span>
                            <span class="fw-bold fs-5" id="total-quantity">0</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <h4 class="fw-bold mb-0 text-dark">Tổng tiền:</h4>
                            <h3 class="fw-bold text-success mb-0" id="total-price">0 đ</h3>
                        </div>

                        <button class="btn btn-success btn-lg w-100 fw-bold shadow-sm" onclick="hienThiQRPOS()">
                            <i class="fa-solid fa-money-bill-wave me-2"></i> THANH TOÁN
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="modalQR_POS" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-qrcode me-2"></i>Thanh toán hóa đơn</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4">
                <p class="mb-2">Khách hàng vui lòng quét mã để thanh toán:</p>
                <h3 class="text-danger fw-bold mb-3" id="modalPosTotalAmount">0 đ</h3>

                <div class="bg-light p-3 rounded mb-3 border">
                    <img id="qrPosImage" src="" alt="QR" class="img-fluid shadow-sm mb-2" style="max-width: 200px;">
                    <p class="small text-muted mb-0">Nội dung CK: <strong id="modalPosContent"></strong></p>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-center border-0 pb-4">
                <button type="button" class="btn btn-secondary px-4 me-2" data-bs-dismiss="modal">Hủy / Sửa đơn</button>

                <button type="button" class="btn btn-success px-4 fw-bold" onclick="thucHienThanhToanPOS()">
                    <i class="fa-solid fa-check-circle me-1"></i>Đã nhận đủ tiền
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let cart = [];
        let grandTotalAmount = 0; // Biến lưu tổng tiền để nhét vào mã QR

        function addToCart(id, name, price, maxStock) {
            if (maxStock <= 0) {
                alert("❌ Sản phẩm này đã HẾT HÀNG!");
                return;
            }
            let existingItem = cart.find(item => item.id === id);
            if (existingItem) {
                if (existingItem.quantity + 1 > maxStock) {
                    alert(`⚠️ Trong kho chỉ còn đúng ${maxStock} sản phẩm này!`);
                    return;
                }
                existingItem.quantity += 1;
            } else {
                cart.push({ id: id, name: name, price: price, quantity: 1, maxStock: maxStock });
            }
            renderCart();
        }

        function changeQuantity(id, delta) {
            let item = cart.find(item => item.id === id);
            if (item) {
                let newQuantity = item.quantity + delta;
                if (newQuantity > item.maxStock) {
                    alert(`⚠️ Trong kho chỉ còn tối đa ${item.maxStock} sản phẩm này!`);
                    return;
                }
                item.quantity = newQuantity;
                if (item.quantity <= 0) {
                    cart = cart.filter(i => i.id !== id);
                }
                renderCart();
            }
        }

        function locSanPham(catId, btnElement) {
            let allBtns = document.querySelectorAll('.filter-btn');
            allBtns.forEach(btn => {
                btn.className = 'btn btn-outline-success bg-white filter-btn';
            });
            btnElement.className = 'btn btn-success fw-bold filter-btn';

            let products = document.querySelectorAll('.product-item');
            products.forEach(p => {
                let pCatId = p.getAttribute('data-category');
                if (catId === 'Tất cả' || pCatId === catId.toString()) {
                    p.style.display = 'block';
                } else {
                    p.style.display = 'none';
                }
            });
        }

        function renderCart() {
            let billContainer = document.querySelector('.bill-items');
            let totalQuantityEl = document.getElementById('total-quantity');
            let totalPriceEl = document.getElementById('total-price');
            billContainer.innerHTML = '';
            let totalQty = 0;
            let totalPrice = 0;

            if (cart.length === 0) {
                billContainer.innerHTML = `
                    <div class="text-center text-muted mt-5 pt-5">
                        <i class="fa-solid fa-cart-arrow-down fa-3x mb-3 opacity-25"></i>
                        <p class="mb-1 fw-bold">Chưa có sản phẩm.</p>
                        <p class="small">Click vào món bên trái để thêm</p>
                    </div>`;
            } else {
                cart.forEach(item => {
                    let itemTotal = item.price * item.quantity;
                    totalQty += item.quantity;
                    totalPrice += itemTotal;
                    billContainer.innerHTML += `
                        <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                            <div class="fw-bold text-dark w-50">${item.name}</div>
                            <div class="d-flex align-items-center">
                                <button class="btn btn-sm btn-outline-danger px-2 py-0" onclick="changeQuantity(${item.id}, -1)">-</button>
                                <span class="mx-2 fw-bold text-dark">${item.quantity}</span>
                                <button class="btn btn-sm btn-outline-success px-2 py-0" onclick="changeQuantity(${item.id}, 1)">+</button>
                            </div>
                            <div class="fw-bold text-primary text-end w-25">
                                ${itemTotal.toLocaleString('vi-VN')} đ
                            </div>
                        </div>`;
                });
            }

            totalQuantityEl.innerText = totalQty;
            totalPriceEl.innerText = totalPrice.toLocaleString('vi-VN') + ' đ';

            // Cập nhật biến tổng tiền để dùng cho hàm QR bên dưới
            grandTotalAmount = totalPrice;
        }

        // ==========================================
        // HÀM HIỆN MÃ QR TRƯỚC KHI GỬI VỀ SERVER
        // ==========================================
        function hienThiQRPOS() {
            if (cart.length === 0) {
                alert("Giỏ hàng đang trống! Vui lòng chọn món trước.");
                return;
            }

            // Gắn số tiền lên Modal QR
            document.getElementById("modalPosTotalAmount").innerText = grandTotalAmount.toLocaleString('vi-VN') + " đ";

            // Tạo chuỗi mã hóa chuyển khoản (Random để không bị trùng)
            let randomCode = Math.floor(1000 + Math.random() * 9000);
            let noiDungCK = "POS" + randomCode;
            document.getElementById("modalPosContent").innerText = noiDungCK;

            // Render ảnh QR ép đúng số tiền cần thanh toán
            document.getElementById("qrPosImage").src = `https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=${noiDungCK}_${grandTotalAmount}`;

            // Bật popup lên
            let posModal = new bootstrap.Modal(document.getElementById('modalQR_POS'));
            posModal.show();
        }

        // ==========================================
        // HÀM GỌI API ĐỂ TRỪ KHO VÀ CỘNG TIỀN VÀO ADMIN
        // ==========================================
        function thucHienThanhToanPOS() {
            // Thay đổi nút thành "Đang xử lý..." để nhân viên không ấn 2 lần
            event.target.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i>Đang lưu...';
            event.target.disabled = true;

            fetch('/Employee/Home/XuLyThanhToanPOS', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(cart)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert("✅ Thanh toán thành công! Hệ thống đã trừ kho và cộng tiền vào Doanh thu.");
                    window.location.reload(); // Load lại trang để làm mới giao diện và tồn kho
                } else {
                    alert("❌ Lỗi: " + data.message);
                    // Phục hồi lại nút nếu bị lỗi
                    event.target.innerHTML = '<i class="fa-solid fa-check-circle me-1"></i>Đã nhận đủ tiền';
                    event.target.disabled = false;
                }
            })
            .catch(error => {
                alert("❌ Lỗi kết nối mạng hoặc lỗi server!");
                event.target.innerHTML = '<i class="fa-solid fa-check-circle me-1"></i>Đã nhận đủ tiền';
                event.target.disabled = false;
            });
        }
    </script>
}