@model IEnumerable<THLTW_B2.Models.Booking>
@{
    Layout = "~/Areas/Employee/Views/Shared/_EmployeeLayout.cshtml";
    ViewData["Title"] = "Quản lý lịch đặt sân";
    var currentTab = ViewBag.CurrentTab ?? "donngay";
}

<style>
    /* BẢN VÁ LỖI GIAO DIỆN CHỒNG CHÉO */
    .dashboard-wrapper {
        margin-left: 260px;
        width: calc(100% - 260px);
        padding: 20px;
        background-color: #f8f9fa;
        min-height: 100vh;
    }

    /* Tinh chỉnh cho màn hình điện thoại (Sidebar bị ẩn/thu gọn) */
    @@media (max-width: 991.98px) {
        .dashboard-wrapper

    {
        margin-left: 0;
        width: 100%;
        padding: 15px;
    }

    }

    .container-fluid {
        width: 100%;
        max-width: 100%;
        padding-left: 0;
        padding-right: 0;
    }

    /* Tinh chỉnh làm đẹp bảng Web */
    .table thead th {
        border-top: none;
        font-size: 13px;
        font-weight: 600;
        color: #555;
        background-color: #f1f4f9;
        padding: 15px 10px;
    }

    .table tbody td {
        border-bottom: 1px solid #f2f2f2;
        padding: 15px 10px;
        vertical-align: middle;
    }

    .nav-pills .nav-link {
        transition: all 0.2s ease;
        border-radius: 8px;
        font-weight: 500;
    }

    .btn-group .btn {
        border-radius: 6px !important;
        margin: 0 2px;
    }

    .custom-card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
    }
</style>

<div class="dashboard-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-calendar-check me-2 text-success"></i>Quản lý Đặt sân</h3>
            <p class="text-muted small mb-0">Xem và xử lý các yêu cầu đặt sân từ khách hàng</p>
        </div>

        <a asp-action="Create" asp-controller="Home" asp-area="Employee" class="btn btn-success shadow-sm px-4 py-2 rounded-3 fw-bold">
            <i class="fa-solid fa-plus me-2"></i>Tạo lịch đặt mới
        </a>
    </div>

    <div class="card custom-card mb-4">
        <div class="card-header bg-white border-0 pt-3 pb-0">
            <ul class="nav nav-pills nav-fill p-1 bg-light rounded-3">
                <li class="nav-item">
                    <a class="nav-link @(currentTab == "donngay" ? "active bg-success shadow" : "text-dark")"
                       href="@Url.Action("YeuCauDatSan", new { tab = "donngay" })">
                        <i class="fa-solid fa-clock-rotate-left me-1"></i> Đơn ngày (Đang chờ)
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentTab == "doncodinh" ? "active bg-success shadow" : "text-dark")"
                       href="@Url.Action("YeuCauDatSan", new { tab = "doncodinh" })">
                        <i class="fa-solid fa-calendar-days me-1"></i> Đơn cố định (Tháng)
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentTab == "tatca" ? "active bg-success shadow" : "text-dark")"
                       href="@Url.Action("YeuCauDatSan", new { tab = "tatca" })">
                        <i class="fa-solid fa-list me-1"></i> Tất cả lịch đặt
                    </a>
                </li>
            </ul>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr class="text-uppercase text-muted">
                            <th class="ps-3">Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Sân bóng</th>
                            <th>Khung giờ</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="fa-solid fa-folder-open fa-3x mb-3 d-block opacity-25"></i>
                                    Hiện chưa có dữ liệu cho mục này.
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-bold text-primary">#@item.Id</td>
                                <td>
                                    <div class="fw-bold text-dark">@(item.User?.FullName ?? "Khách lẻ")</div>
                                </td>
                                <td>
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-2 py-1">
                                        <i class="fa-solid fa-futbol me-1"></i> @item.SoccerField?.Name
                                    </span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@(item.User?.FullName ?? "Khách lẻ")</div>
                                    @if (item.Note != null && item.Note.Contains("Trận giao hữu"))
                                    {
                                        <span class="badge bg-info-subtle text-info border border-info-subtle small">
                                            <i class="fa-solid fa-handshake me-1"></i> Giao hữu
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.TimeSlot</div>
                                    <small class="text-muted">@item.BookingDate.ToString("dd/MM/yyyy")</small>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.TotalPrice.ToString("N0") đ</div>
                                    <small class="text-warning fw-bold">Cọc: @item.DepositAmount.ToString("N0") đ</small>
                                </td>
                                <td>
                                    @{
                                        string badgeClass = item.Status == "Chờ duyệt" ? "bg-warning text-dark" :
                                        item.Status == "Đã hoàn thành" ? "bg-success" :
                                        item.Status == "Đã hủy" ? "bg-danger" : "bg-info";
                                    }
                                    <span class="badge @badgeClass px-3 py-2 rounded-pill">@item.Status</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        @if (item.Status == "Chờ duyệt")
                                        {
                                            <form asp-action="XacNhanDon" asp-route-id="@item.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-warning mx-1" title="Xác nhận">
                                                    <i class="fa-solid fa-check"></i>
                                                </button>
                                            </form>
                                        }
                                        else if (item.Status != "Đã hoàn thành" && item.Status != "Đã hủy")
                                        {
                                            <form asp-action="DuyetDon" asp-route-id="@item.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-success mx-1" title="Hoàn thành">
                                                    <i class="fa-solid fa-cash-register"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="HuyDon" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Hủy lịch đặt này?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger mx-1" title="Hủy">
                                                <i class="fa-solid fa-xmark"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>