@model IEnumerable<THLTW_B2.Models.UserListViewModel>
@{
    ViewData["Title"] = "Quản lý nhân viên";

    // Lọc ra danh sách những người có Role là Admin hoặc Employee
    var employeeList = Model.Where(u => u.Roles != null &&
                                        (u.Roles.Contains("Admin") || u.Roles.Contains("Employee")))
                            .ToList();
}

<div class="container-fluid py-3">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h3 class="fw-bold text-dark"><i class="bi bi-people-fill text-primary me-2"></i>Đội Ngũ Nhân Viên</h3>
            <p class="text-muted mb-0">Quản lý tài khoản và phân quyền truy cập hệ thống</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-person-plus-fill me-2"></i> Cấp tài khoản mới
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary small fw-bold text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Tài khoản</th>
                        <th>Email</th>
                        <th>Vai trò (Quyền)</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (employeeList.Any())
                    {
                        // Dùng danh sách đã lọc (employeeList) thay cho Model gốc
                        @foreach (var user in employeeList)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                            <i class="bi bi-person-badge fs-5"></i>
                                        </div>
                                        <span class="fw-bold">@user.UserName</span>
                                    </div>
                                </td>
                                <td>@user.Email</td>
                                <td>
                                    @foreach (var role in user.Roles)
                                    {
                                        var badgeClass = role switch
                                        {
                                            "Admin" => "bg-danger",
                                            "Employee" => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                        <span class="badge @badgeClass rounded-pill px-3 py-2 me-1">
                                            <i class="bi bi-shield-check me-1"></i> @role
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2">
                                        <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i> Hoạt động
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a asp-controller="Employee" asp-action="EditRoles" asp-route-userId="@user.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 me-2" title="Chỉnh sửa quyền">
                                            <i class="bi bi-shield-lock me-1"></i> Quyền
                                        </a>

                                        <form asp-controller="Employee" asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-light rounded-circle text-danger shadow-sm"
                                                    onclick="return confirm('Bạn có chắc chắn muốn thu hồi tài khoản của @user.UserName?')" title="Xóa tài khoản">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-person-x fs-1 d-block mb-2"></i>
                                Không tìm thấy tài khoản Quản trị viên hoặc Nhân viên nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>