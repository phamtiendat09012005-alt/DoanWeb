@model IEnumerable<THLTW_B2.Models.EmployeeShift>

@{
    ViewData["Title"] = "Bảng Chấm Công - Xếp Ca";
    int thang = ViewBag.Thang;
    int nam = ViewBag.Nam;
    int soNgay = ViewBag.SoNgayTrongThang;

    // Lấy danh sách đã được lọc SẠCH từ Controller
    var nhanViens = ViewBag.DanhSachNhanVien as List<THLTW_B2.Models.ApplicationUser> ?? new List<THLTW_B2.Models.ApplicationUser>();
}

<style>
    /* Đóng băng cột đầu tiên (Tên nhân viên) khi cuộn ngang */
    .sticky-col {
        position: sticky;
        left: 0;
        background-color: #212529 !important;
        color: #0d6efd !important;
        z-index: 2;
        min-width: 180px;
        box-shadow: 2px 0 5px rgba(0,0,0,0.1);
    }

    .cell-shift {
        cursor: pointer;
        min-width: 50px;
        height: 45px;
        vertical-align: middle;
        transition: 0.1s;
    }

        .cell-shift:hover {
            background-color: #e9ecef !important;
            outline: 2px solid #0d6efd;
            z-index: 1;
        }

    /* Màu sắc viết tắt cho các ca */
    .ca-S {
        background-color: #ffeeba;
        color: #856404;
        font-weight: bold;
        border-radius: 4px;
        padding: 4px;
    }

    .ca-C {
        background-color: #b8daff;
        color: #004085;
        font-weight: bold;
        border-radius: 4px;
        padding: 4px;
    }

    .ca-T {
        background-color: #c3e6cb;
        color: #155724;
        font-weight: bold;
        border-radius: 4px;
        padding: 4px;
    }
</style>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary"><i class="bi bi-grid-3x3"></i> Bảng Chấm Công Tháng @thang/@nam</h3>

        <form method="get" class="d-flex gap-2">
            <select name="thang" class="form-select form-select-sm">
                @for (int i = 1; i <= 12; i++)
                {
                    <option value="@i" selected="@(i == thang)">Tháng @i</option>
                }
            </select>
            <select name="nam" class="form-select form-select-sm">
                <option value="@nam">Năm @nam</option>
                <option value="@(nam - 1)">Năm @(nam - 1)</option>
            </select>
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Xem</button>
        </form>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 650px; overflow-x: auto;">
                <table class="table table-bordered table-sm text-center mb-0" style="white-space: nowrap;">
                    <thead class="table-dark" style="position: sticky; top: 0; z-index: 3;">
                        <tr>
                            <th class="sticky-col py-3">Tên Nhân Viên</th>
                            @for (int i = 1; i <= soNgay; i++)
                            {
                                <th style="min-width: 50px;" class="py-3">@i</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (nhanViens.Any())
                        {
                            @foreach (var nv in nhanViens)
                            {
                                <tr>
                                    <td class="sticky-col fw-bold text-start ps-3 align-middle">@(nv.FullName ?? nv.UserName)</td>

                                    @for (int i = 1; i <= soNgay; i++)
                                    {
                                        var ca = Model.FirstOrDefault(s => s.UserId == nv.Id && s.WorkDate.Day == i);

                                        string textCa = ""; string classCa = "";
                                        if (ca != null)
                                        {
                                            if (ca.ShiftName.Contains("Sáng")) { textCa = "S"; classCa = "ca-S"; }
                                            else if (ca.ShiftName.Contains("Chiều")) { textCa = "C"; classCa = "ca-C"; }
                                            else if (ca.ShiftName.Contains("Tối")) { textCa = "T"; classCa = "ca-T"; }
                                            else { textCa = "X"; classCa = "bg-secondary text-white rounded px-1"; }
                                        }

                                        <td class="cell-shift"
                                            onclick="openShiftModal('@nv.Id', '@(nv.FullName ?? nv.UserName)', @i, '@(ca?.ShiftName ?? "")', @(ca?.ShiftWage ?? 70000))"
                                            title="Click để xếp ca">
                                            @if (!string.IsNullOrEmpty(textCa))
                                            {
                                                <div class="@classCa">@textCa</div>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@(soNgay + 1)" class="text-center py-4 text-muted">
                                    Không có nhân viên hoặc quản trị viên nào trong hệ thống.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="p-3 bg-light border-top small fw-bold">
                Chú thích: <span class="ca-S mx-2">S: Ca Sáng</span> <span class="ca-C mx-2">C: Ca Chiều</span> <span class="ca-T mx-2">T: Ca Tối</span>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="shiftModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content shadow">
            <div class="modal-header bg-primary text-white py-2">
                <h6 class="modal-title fw-bold" id="modalTitle">Xếp ca ngày X</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3">
                <input type="hidden" id="editUserId">
                <input type="hidden" id="editDay">

                <label class="form-label small fw-bold">Chọn Ca:</label>
                <select id="editShiftName" class="form-select mb-3">
                    <option value="">-- Nghỉ / Xóa Ca --</option>
                    <option value="Ca Sáng (06:00 - 12:00)">Ca Sáng (06:00 - 12:00)</option>
                    <option value="Ca Chiều (12:00 - 18:00)">Ca Chiều (12:00 - 18:00)</option>
                    <option value="Ca Tối (18:00 - 24:00)">Ca Tối (18:00 - 24:00)</option>
                </select>

                <label class="form-label small fw-bold">Mức Lương (VNĐ):</label>
                <input type="number" id="editShiftWage" class="form-control" value="70000" step="10000">
            </div>
            <div class="modal-footer p-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary btn-sm fw-bold w-50" onclick="saveShift()">Lưu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentMonth = @thang;
        let currentYear = @nam;
        let myModal = new bootstrap.Modal(document.getElementById('shiftModal'));

        function openShiftModal(userId, userName, day, shiftName, shiftWage) {
            document.getElementById('modalTitle').innerText = userName + " - Ngày " + day + "/" + currentMonth;
            document.getElementById('editUserId').value = userId;
            document.getElementById('editDay').value = day;
            document.getElementById('editShiftName').value = shiftName;
            document.getElementById('editShiftWage').value = shiftWage;
            myModal.show();
        }

        async function saveShift() {
            const uid = document.getElementById('editUserId').value;
            const d = document.getElementById('editDay').value;
            const sName = document.getElementById('editShiftName').value;
            const sWage = document.getElementById('editShiftWage').value;

            const formData = new FormData();
            formData.append('userId', uid);
            formData.append('day', d);
            formData.append('month', currentMonth);
            formData.append('year', currentYear);
            formData.append('shiftName', sName);
            formData.append('shiftWage', sWage);

            try {
                const response = await fetch('/Admin/Payroll/LuuCaLamAjax', {
                    method: 'POST',
                    body: formData
                });
                if(response.ok) {
                    location.reload();
                } else {
                    alert("Có lỗi xảy ra khi lưu ca!");
                }
            } catch(e) { console.error(e); }
        }
    </script>
}