@model IEnumerable<THLTW_B2.Models.EmployeeShift>

@{
    ViewData["Title"] = "Chi Tiết Ca Làm Việc";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary"><i class="bi bi-table"></i> Bảng Kê Chi Tiết Ca Làm Việc</h3>
        <div>
            <a href="/Admin/Payroll/Create" class="btn btn-primary btn-sm fw-bold me-2">
                <i class="bi bi-plus-circle"></i> Phân Ca Mới
            </a>
            <button onclick="exportTableToExcel('excelTable', 'BangKeCaLamViec')" class="btn btn-success btn-sm fw-bold">
                <i class="bi bi-file-earmark-excel"></i> Xuất Excel
            </button>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                <table class="table table-bordered table-hover table-sm align-middle mb-0 text-center" id="excelTable">
                    <thead class="table-dark" style="position: sticky; top: 0; z-index: 1;">
                        <tr>
                            <th style="width: 50px;">STT</th>
                            <th class="text-start">Ngày Làm Việc</th>
                            <th class="text-start">Tên Nhân Viên</th>
                            <th class="text-start">Ca Làm Việc</th>
                            <th class="text-end">Mức Lương (VNĐ)</th>
                            <th>Điểm Danh</th>
                            <th>Thanh Toán</th>
                            <th>Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">Chưa có dữ liệu ca làm việc nào.</td>
                            </tr>
                        }
                        else
                        {
                            int stt = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@(stt++)</td>
                                    <td class="text-start fw-bold text-primary">@item.WorkDate.ToString("dd/MM/yyyy")</td>
                                    <td class="text-start fw-bold">@(item.User?.FullName ?? item.User?.UserName)</td>
                                    <td class="text-start">@item.ShiftName</td>
                                    <td class="text-end text-danger fw-bold">@item.ShiftWage.ToString("N0")</td>

                                    <td>
                                        @if (item.IsAttended)
                                        {
                                            <span class="badge bg-success">Có mặt</span>
                                        }
                                        else
                                        {

                                            <span class="badge bg-danger">Vắng mặt</span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.IsPaid)
                                        {
                                            <span class="badge bg-secondary">Đã nhận tiền</span>
                                        }
                                        else
                                        {

                                            <span class="badge bg-warning text-dark">Chưa thanh toán</span>
                                        }
                                    </td>

                                    <td>
                                        <button onclick="xoaCaLam(@item.Id)" class="btn btn-sm btn-outline-danger" title="Xóa ca này"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // HÀM XUẤT HTML TABLE THÀNH FILE EXCEL (Đã fix lỗi tràn code)
        function exportTableToExcel(tableID, filename = 'BangKeCaLamViec') {
            var table = document.getElementById(tableID);

            // Lấy toàn bộ HTML của bảng
            var html = table.outerHTML;

            // Tách nhỏ các thẻ đóng để Razor/Trình duyệt không bị lú
            var template = '<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><meta charset="UTF-8"><' + '/head><body>' + html + '<' + '/body><' + '/html>';

            // Tạo đối tượng Blob để tải file
            var blob = new Blob([template], { type: 'application/vnd.ms-excel;charset=utf-8' });
            var url = window.URL.createObjectURL(blob);

            // Tạo thẻ <a> ẩn để tự động click tải về
            var a = document.createElement('a');
            a.href = url;
            a.download = filename + '.xls';
            document.body.appendChild(a);
            a.click();

            // Dọn dẹp sau khi tải xong
            document.body.removeChild(a);
            window.URL.revokeObjectURL(url);
        }

        /// HÀM XÓA CA LÀM
        async function xoaCaLam(id) {
            if (confirm("Bạn có chắc chắn muốn xóa ca làm việc này không?")) {
                try {
                    const response = await fetch(`/Admin/Payroll/DeleteShift/${id}`, {
                        method: 'POST'
                    });
                    const result = await response.json();

                    if (result.success) {
                        alert("Đã xóa thành công!");
                        location.reload(); // Tải lại trang
                    } else {
                        alert("Lỗi: " + result.message);
                    }
                } catch (e) {
                    console.error("Lỗi khi xóa:", e);
                }
            }
        
        }
    </script>
}