@model THLTW_B2.Models.EmployeeShift

@{
    ViewData["Title"] = "Phân Ca Làm Việc";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-calendar-plus"></i> Thêm Ca Làm Việc Cho Nhân Viên</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label asp-for="UserId" class="form-label fw-bold">Chọn Nhân Viên <span class="text-danger">*</span></label>
                            <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId">
                                <option value="">-- Vui lòng chọn nhân viên --</option>
                            </select>
                            <span asp-validation-for="UserId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="WorkDate" class="form-label fw-bold">Ngày Làm Việc <span class="text-danger">*</span></label>
                            <input asp-for="WorkDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="WorkDate" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ShiftName" class="form-label fw-bold">Ca Làm Việc <span class="text-danger">*</span></label>
                            <select asp-for="ShiftName" class="form-select">
                                <option value="Ca Sáng (06:00 - 12:00)">Ca Sáng (06:00 - 12:00)</option>
                                <option value="Ca Chiều (12:00 - 18:00)">Ca Chiều (12:00 - 18:00)</option>
                                <option value="Ca Tối (18:00 - 24:00)">Ca Tối (18:00 - 24:00)</option>
                            </select>
                            <span asp-validation-for="ShiftName" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ShiftWage" class="form-label fw-bold">Tiền Lương Ca Này (VNĐ) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="ShiftWage" type="number" class="form-control" min="10000" step="10000" value="70000" placeholder="VD: 70000">
                                <span class="input-group-text fw-bold">VNĐ</span>
                            </div>
                            <span asp-validation-for="ShiftWage" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại bảng lương
                            </a>
                            <button type="submit" class="btn btn-primary fw-bold px-4 shadow-sm">
                                <i class="bi bi-save"></i> Lưu Ca Làm Việc
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>