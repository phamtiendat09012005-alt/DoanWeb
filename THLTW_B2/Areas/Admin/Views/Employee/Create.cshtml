@model THLTW_B2.Areas.Admin.Controllers.CreateEmployeeViewModel

@{
    ViewData["Title"] = "Cấp tài khoản nhân viên";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">

                    <div class="text-center mb-4">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-person-plus-fill fs-2"></i>
                        </div>
                        <h4 class="fw-bold">Cấp Tài Khoản Nhân Viên</h4>
                        <p class="text-muted small">Thông tin này sẽ được dùng để đăng nhập vào hệ thống quản trị</p>
                    </div>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-bold small text-uppercase text-secondary">Họ và tên nhân viên</label>
                            <input asp-for="FullName" class="form-control bg-light border-0 py-2" placeholder="VD: Nguyễn Văn A" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold small text-uppercase text-secondary">Email đăng nhập</label>
                            <input asp-for="Email" class="form-control bg-light border-0 py-2" placeholder="nhanvien@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-bold small text-uppercase text-secondary">Mật khẩu tạm thời</label>
                            <input asp-for="Password" class="form-control bg-light border-0 py-2" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                            <div class="form-text mt-1" style="font-size: 0.75rem;">
                                <i class="bi bi-info-circle me-1"></i> Mật khẩu nên có ít nhất 6 ký tự.
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="SelectedRole" class="form-label fw-bold small text-uppercase text-secondary">Vai trò hệ thống</label>
                            <select asp-for="SelectedRole" class="form-select bg-light border-0 py-2" asp-items="ViewBag.RoleList">
                                <option value="">-- Chọn quyền hạn --</option>
                            </select>
                            <span asp-validation-for="SelectedRole" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill py-2 fw-bold shadow-sm">
                                <i class="bi bi-shield-check me-2"></i> Kích Hoạt Tài Khoản
                            </button>
                            <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none small">Hủy và quay lại</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}