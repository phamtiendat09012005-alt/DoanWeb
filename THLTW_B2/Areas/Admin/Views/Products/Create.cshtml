@model THLTW_B2.Models.Product

@{
    ViewData["Title"] = "Thêm Mới Sản Phẩm";
    // File Layout sẽ tự động được nhận diện nhờ _ViewStart.cshtml
}

<div class="container-fluid py-3">
    <div class="row mb-4">
        <div class="col-md-8">
            <h3 class="mb-0 text-dark fw-bold">
                <i class="bi bi-plus-circle-fill text-primary me-2"></i>Thêm Dịch Vụ Mới
            </h3>
            <p class="text-muted mt-1">Điền thông tin chi tiết để thêm sản phẩm vào kho sân bóng.</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Trở về kho
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">

                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-12 mb-2">
                                <label asp-for="Name" class="form-label fw-bold"></label>
                                <input asp-for="Name" class="form-control form-control-lg bg-light border-0" placeholder="VD: Nước suối Aquafina, Áo Pitch..." />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12 mb-2">
                                <label asp-for="CategoryId" class="form-label fw-bold"></label>
                                <select asp-for="CategoryId" class="form-select form-select-lg bg-light border-0" asp-items="ViewBag.CategoryId">
                                    <option value="">-- Chọn danh mục sản phẩm --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-2">
                                <label asp-for="Price" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <input asp-for="Price" class="form-control form-control-lg bg-light border-0" type="number" min="0" placeholder="0" />
                                    <span class="input-group-text bg-light border-0">VNĐ</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-2">
                                <label asp-for="StockQuantity" class="form-label fw-bold"></label>
                                <input asp-for="StockQuantity" class="form-control form-control-lg bg-light border-0" type="number" min="0" placeholder="0" />
                                <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-4">
                                <label asp-for="Unit" class="form-label fw-bold"></label>
                                <input asp-for="Unit" class="form-control form-control-lg bg-light border-0" placeholder="VD: Chai, Lon, Cái, Giờ..." />
                                <span asp-validation-for="Unit" class="text-danger small"></span>
                            </div>
                            <div class="col-12 mb-4">
                                <label asp-for="ImageUpload" class="form-label fw-bold"></label>
                                <input asp-for="ImageUpload" class="form-control form-control-lg bg-light border-0" type="file" accept="image/*" />
                                <span asp-validation-for="ImageUpload" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-save me-2"></i> Lưu Sản Phẩm
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}