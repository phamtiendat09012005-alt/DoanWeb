@model THLTW_B2.Models.Product

@{
    ViewData["Title"] = "Chỉnh Sửa Sản Phẩm";
}

<div class="container-fluid py-3">
    <div class="row mb-4">
        <div class="col-md-8">
            <h3 class="mb-0 text-dark fw-bold">
                <i class="bi bi-pencil-square text-warning me-2"></i>Chỉnh Sửa Dịch Vụ
            </h3>
            <p class="text-muted mt-1">Cập nhật thông tin giá bán hoặc số lượng tồn kho.</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Trở về kho
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">

                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="ProductId" />
                        <input type="hidden" asp-for="ImageUrl" />

                        <div class="row g-3">
                            <div class="col-12 mb-2">
                                <label asp-for="Name" class="form-label fw-bold"></label>
                                <input asp-for="Name" class="form-control form-control-lg bg-light border-0" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12 mb-2">
                                <label asp-for="CategoryId" class="form-label fw-bold"></label>
                                <select asp-for="CategoryId" class="form-select form-select-lg bg-light border-0" asp-items="ViewBag.CategoryId"></select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-2">
                                <label asp-for="Price" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <input asp-for="Price" class="form-control form-control-lg bg-light border-0" type="number" min="0" />
                                    <span class="input-group-text bg-light border-0">VNĐ</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-2">
                                <label asp-for="StockQuantity" class="form-label fw-bold"></label>
                                <input asp-for="StockQuantity" class="form-control form-control-lg bg-light border-0" type="number" min="0" />
                                <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-2">
                                <label asp-for="Unit" class="form-label fw-bold"></label>
                                <input asp-for="Unit" class="form-control form-control-lg bg-light border-0" />
                                <span asp-validation-for="Unit" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-4">
                                <label asp-for="ImageUpload" class="form-label fw-bold">Thay đổi hình ảnh</label>
                                <input asp-for="ImageUpload" class="form-control form-control-lg bg-light border-0" type="file" accept="image/*" />

                                <div class="mt-3">
                                    <small class="text-muted d-block mb-2">Ảnh hiện tại:</small>
                                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                    {
                                        <img src="@Model.ImageUrl" alt="Current Image" class="img-thumbnail shadow-sm" style="max-width: 150px; border-radius: 10px;" />
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border">Chưa có ảnh</span>
                                    }
                                </div>
                                <span asp-validation-for="ImageUpload" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-warning btn-lg rounded-pill fw-bold shadow-sm text-dark">
                                <i class="bi bi-check2-circle me-2"></i> Cập Nhật Thay Đổi
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}