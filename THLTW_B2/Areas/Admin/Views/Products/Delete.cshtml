@model THLTW_B2.Models.Product

@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<div class="container-fluid py-4 d-flex justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm rounded-4 mt-3">
            <div class="card-header bg-danger text-white py-3 rounded-top-4">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Xác nhận xóa dữ liệu
                </h5>
            </div>

            <div class="card-body p-4 text-center">
                <i class="bi bi-trash3 text-danger mb-3" style="font-size: 4rem; opacity: 0.8;"></i>
                <h4 class="text-dark fw-bold mb-3">Bạn có chắc chắn muốn xóa dịch vụ này?</h4>

                <div class="bg-light p-3 rounded-3 text-start mb-4 border">
                    <p class="mb-1"><strong>Tên sản phẩm:</strong> <span class="text-primary">@Model.Name</span></p>
                    <p class="mb-1"><strong>Giá bán:</strong> <span class="text-danger">@Model.Price.ToString("N0") VNĐ</span></p>
                    <p class="mb-0"><strong>Tồn kho:</strong> @Model.StockQuantity @Model.Unit</p>
                </div>

                <p class="text-muted small mb-4">
                    <i class="bi bi-info-circle"></i> Hành động này sẽ xóa vĩnh viễn dữ liệu khỏi hệ thống và <strong class="text-danger">không thể khôi phục lại được</strong>. Hình ảnh đính kèm (nếu có) cũng sẽ bị xóa khỏi máy chủ.
                </p>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="ProductId" />

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-pill fw-bold">
                            Hủy bỏ, quay lại
                        </a>
                        <button type="submit" class="btn btn-danger px-4 py-2 rounded-pill fw-bold shadow-sm">
                            <i class="bi bi-trash me-1"></i> Xóa vĩnh viễn
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>