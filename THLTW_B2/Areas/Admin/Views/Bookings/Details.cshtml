@model THLTW_B2.Models.Booking
@{
    ViewData["Title"] = "Chi Tiết Hóa Đơn";
    decimal remainingAmount = Model.TotalPrice - Model.DepositAmount;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary p-4 text-white d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold mb-0 text-uppercase"><i class="bi bi-receipt me-2"></i>Hóa Đơn Sân</h3>
                        <span class="text-white-50">Mã đơn: #BK@(Model.Id.ToString("D4"))</span>
                    </div>
                    <div>
                        <button class="btn btn-light rounded-pill px-3 fw-bold shadow-sm" onclick="window.print()">
                            <i class="bi bi-printer-fill me-1"></i> In hóa đơn
                        </button>
                    </div>
                </div>

                <div class="card-body p-5">
                    <div class="row mb-5">
                        <div class="col-sm-6">
                            <h6 class="text-muted text-uppercase small fw-bold">Khách hàng</h6>
                            <h5 class="fw-bold mb-1 text-dark">@(Model.User?.FullName ?? "Khách vãng lai")</h5>
                            <p class="text-muted small mb-0"><i class="bi bi-telephone-fill me-1"></i> @(Model.User?.PhoneNumber ?? "Không có SĐT")</p>
                        </div>
                        <div class="col-sm-6 text-sm-end mt-4 mt-sm-0">
                            <h6 class="text-muted text-uppercase small fw-bold">Thông tin phiếu</h6>
                            <p class="mb-1 text-dark"><strong>Trạng thái:</strong> <span class="badge bg-success rounded-pill px-2">@Model.Status</span></p>
                            <p class="text-muted small mb-0"><strong>Ngày lập:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>

                    <div class="table-responsive mb-4">
                        <table class="table table-bordered align-middle">
                            <thead class="table-light text-uppercase small fw-bold text-muted">
                                <tr>
                                    <th class="py-3 ps-3">Dịch Vụ Sân</th>
                                    <th class="text-center py-3">Khung Giờ</th>
                                    <th class="text-end py-3 pe-3">Thành Tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="py-3 ps-3">
                                        <span class="fw-bold text-primary fs-6">@(Model.SoccerField?.Name ?? "Sân đã xóa")</span><br />
                                        <small class="text-muted">Ngày đá: @Model.BookingDate.ToString("dd/MM/yyyy")</small>
                                    </td>
                                    <td class="text-center py-3 fw-bold">@Model.TimeSlot</td>
                                    <td class="text-end py-3 fw-bold fs-6 pe-3">@Model.TotalPrice.ToString("N0") ₫</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="row justify-content-end mb-4">
                        <div class="col-md-6 col-lg-5">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted fw-bold">Tổng cộng:</span>
                                <span class="fw-bold text-dark">@Model.TotalPrice.ToString("N0") ₫</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted fw-bold">Đã đặt cọc:</span>
                                <span class="fw-bold text-success">- @Model.DepositAmount.ToString("N0") ₫</span>
                            </div>
                            <hr class="border-secondary border-opacity-25" />
                            <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded-3">
                                <span class="h6 fw-bold text-danger mb-0">Khách cần thanh toán:</span>
                                <span class="h5 fw-bold text-danger mb-0">@remainingAmount.ToString("N0") ₫</span>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <div class="bg-light p-3 rounded-3 mb-4 border border-info border-opacity-25">
                            <small class="text-info fw-bold d-block mb-1"><i class="bi bi-info-circle me-1"></i>Ghi chú từ khách:</small>
                            <p class="small mb-0 text-muted fst-italic">@Model.Note</p>
                        </div>
                    }

                    <div class="text-center mt-5">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-5 fw-bold"><i class="bi bi-arrow-left me-2"></i>Quay lại danh sách</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        body * {
            visibility: hidden;
        }

        .card, .card * {
            visibility: visible;
        }

        .card {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            box-shadow: none !important;
        }

        .btn {
            display: none !important;
        }
    }
</style>