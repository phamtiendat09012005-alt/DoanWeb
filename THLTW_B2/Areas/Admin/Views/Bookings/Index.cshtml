@{
    ViewData["Title"] = "Quản Lý Lịch Sân";
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom-0 d-flex justify-content-between align-items-center flex-wrap">
            <h4 class="fw-bold mb-0 text-primary"><i class="bi bi-kanban me-2"></i>QUẢN LÝ LỊCH SÂN</h4>

            <ul class="nav nav-pills bg-light rounded-pill p-1 shadow-sm mt-2 mt-md-0" id="pills-tab" role="tablist">
                <li class="nav-item"><button class="nav-link active rounded-pill fw-bold px-4" data-bs-toggle="pill" data-bs-target="#tab-active">Lịch đang chạy</button></li>
                <li class="nav-item"><button class="nav-link rounded-pill fw-bold px-4 text-success" data-bs-toggle="pill" data-bs-target="#tab-done">Đã hoàn thành</button></li>
                <li class="nav-item"><button class="nav-link rounded-pill fw-bold px-4 text-warning" data-bs-toggle="pill" data-bs-target="#tab-pending">Kèo chờ ghép</button></li>
            </ul>
        </div>

        <div class="card-body p-0">
            <div class="tab-content">
                <div class="tab-pane fade show active" id="tab-active">@await Html.PartialAsync("_BookingTablePartial", (List<THLTW_B2.Models.BookingHistoryViewModel>)ViewBag.ActiveBookings)</div>
                <div class="tab-pane fade" id="tab-done">@await Html.PartialAsync("_BookingTablePartial", (List<THLTW_B2.Models.BookingHistoryViewModel>)ViewBag.CompletedBookings)</div>
                <div class="tab-pane fade" id="tab-pending">@await Html.PartialAsync("_BookingTablePartial", (List<THLTW_B2.Models.BookingHistoryViewModel>)ViewBag.PendingMatches)</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateStatus(id, isMatch, newStatus) {
            let msg = newStatus === 'Đã hoàn thành'
                ? "Xác nhận sân này đã đá xong và thu đủ tiền?"
                : "Cảnh báo: Bạn có chắc chắn muốn HỦY đơn này không?";

            if (!confirm(msg)) return;

            // Sử dụng FormData để gửi dữ liệu chuẩn xác lên Controller
            const formData = new FormData();
            formData.append('id', id);
            formData.append('isMatch', isMatch);
            formData.append('newStatus', newStatus);

            // Sử dụng Javascript thuần (fetch) thay vì jQuery
            fetch('/Admin/Bookings/UpdateStatus', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(res => {
                if (res.success) {
                    alert("Cập nhật thành công!");
                    location.reload(); // Tự động load lại trang để đơn nhảy sang tab khác
                } else {
                    alert("Có lỗi xảy ra: " + res.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert("Lỗi kết nối đến máy chủ.");
            });
        }
    </script>
}