@model IEnumerable<THLTW_B2.Models.Booking>

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3">
            <h4 class="fw-bold mb-0 text-primary"><i class="bi bi-calendar-check me-2"></i>Quản Lý Đặt Sân</h4>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success m-3">@TempData["SuccessMessage"]</div>
        }

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Mã Đơn</th>
                            <th>Khách Hàng</th>
                            <th>Sân Bóng</th>
                            <th>Thời Gian</th>
                            <th>Tổng Tiền</th>
                            <th>Trạng Thái</th>
                            <th class="text-center">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#BK@(item.Id.ToString("D4"))</td>
                                <td>
                                    <div class="fw-bold">@(item.User?.FullName ?? "N/A")</div>
                                    <small class="text-muted">@(item.User?.PhoneNumber)</small>
                                </td>
                                <td><span class="badge bg-info text-dark">@(item.SoccerField?.Name)</span></td>
                                <td>
                                    <div><i class="bi bi-calendar-event me-1"></i>@item.BookingDate.ToString("dd/MM/yyyy")</div>
                                    <small class="fw-bold text-dark">@item.TimeSlot</small>
                                </td>
                                <td class="fw-bold text-success">@item.TotalPrice.ToString("N0") ₫</td>
                                <td>
                                    @{
                                        var badgeClass = item.Status switch
                                        {
                                            "Đã cọc" => "bg-primary",
                                            "Đã hoàn thành" => "bg-success",
                                            "Đã hủy" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass rounded-pill px-3">@item.Status</span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="bi bi-pencil-square me-1"></i> Xử lý
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>