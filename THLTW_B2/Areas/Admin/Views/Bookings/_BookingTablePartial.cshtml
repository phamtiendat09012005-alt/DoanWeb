@model List<THLTW_B2.Models.BookingHistoryViewModel>

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light text-uppercase small fw-bold text-secondary">
            <tr>
                <th class="ps-4">Mã Đơn</th>
                <th>Khách Hàng / Đội Bóng</th>
                <th>Sân & Thời Gian</th>
                <th>Phân Loại</th>
                <th>Trạng Thái</th>
                <th class="text-center">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-dark">
                            #@(item.IsMatch ? "MR" : "BK")@item.Id.ToString("D4")
                        </td>
                        <td>
                            <div class="fw-bold text-primary">@item.CustomerName</div>
                            @if (item.IsMatch && !string.IsNullOrEmpty(item.OpponentName))
                            {
                                <small class="text-success fw-bold"><i class="bi bi-vs-circle me-1"></i>VS: @item.OpponentName</small>
                            }
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border mb-1"><i class="bi bi-geo-alt-fill text-danger me-1"></i>@item.PitchName</span>
                            <div class="small fw-bold text-muted">@item.Date.ToString("dd/MM/yyyy") | @item.TimeSlot</div>
                        </td>
                        <td>
                            <span class="small @(item.IsMatch ? "text-warning fw-bold" : "text-secondary")">
                                <i class="bi @(item.IsMatch ? "bi-people-fill" : "bi-person-fill")"></i> @item.Type
                            </span>
                        </td>
                        <td>
                            @{
                                var badgeClass = item.Status switch
                                {
                                    "Đã hoàn thành" => "bg-success",
                                    "Đã có đối thủ" => "bg-info text-dark",
                                    "Đã cọc" => "bg-primary",
                                    "Đang chờ đối thủ" => "bg-warning text-dark",
                                    "Đã hủy" => "bg-danger",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass rounded-pill px-3 py-2">@item.Status</span>
                        </td>
                        <td class="text-center">
                            @if (item.Status == "Đã hoàn thành")
                            {
                                // LOGIC 1: Đã xong -> Chỉ xem chi tiết
                                <a asp-action="Details" asp-route-id="@item.Id" asp-route-isMatch="@item.IsMatch" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                    <i class="bi bi-eye"></i> Xem
                                </a>
                            }
                            else if (item.Status == "Đã hủy")
                            {
                                // LOGIC 2: Đã hủy -> Không làm gì cả
                                <span class="text-muted small fst-italic">Đã hủy</span>
                            }
                            else if (item.Status == "Đang chờ đối thủ")
                            {
                                // LOGIC 3: Kèo đang treo -> Admin chỉ được quyền Hủy (Xóa bài rác)
                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="updateStatus(@item.Id, true, 'Đã hủy')">
                                    <i class="bi bi-trash"></i> Hủy kèo
                                </button>
                            }
                            else
                            {
                                // LOGIC 4: Đang diễn ra (Đã cọc / Đã có đối thủ) -> Nút Chốt Hoàn thành & Nút Hủy
                                <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                    <button class="btn btn-sm btn-success px-3 fw-bold" onclick="updateStatus(@item.Id, @item.IsMatch.ToString().ToLower(), 'Đã hoàn thành')">
                                        <i class="bi bi-check2-circle"></i> Xong
                                    </button>
                                    <button class="btn btn-sm btn-danger px-2 border-0" onclick="updateStatus(@item.Id, @item.IsMatch.ToString().ToLower(), 'Đã hủy')" title="Hủy lịch">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-2 d-block mb-2 opacity-50"></i>Danh sách trống.</td></tr>
            }
        </tbody>
    </table>
</div>