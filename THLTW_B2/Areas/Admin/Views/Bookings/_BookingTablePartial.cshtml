@model List<THLTW_B2.Models.BookingHistoryViewModel>

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light text-uppercase small fw-bold">
            <tr>
                <th class="ps-4">Mã Đơn</th>
                <th>Khách Hàng / Đội bóng</th>
                <th>Sân Bóng</th>
                <th>Thời Gian</th>
                <th>Trạng Thái</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-secondary">#@item.Id</td>
                        <td>
                            <div class="fw-bold text-primary" style="cursor:pointer; text-decoration: underline;" onclick="viewTeamStats('@item.CustomerName')">
                                @item.CustomerName
                            </div>
                            @if (item.IsMatch && !string.IsNullOrEmpty(item.OpponentName))
                            {
                                <div class="small text-success fw-bold" style="cursor:pointer" onclick="viewTeamStats('@item.OpponentName')">
                                    <i class="bi bi-vs-circle"></i> VS: @item.OpponentName
                                </div>
                            }
                        </td>
                        <td><span class="badge bg-info bg-opacity-10 text-dark border border-info border-opacity-10 px-3">@item.PitchName</span></td>
                        <td>
                            <div class="small text-muted">@item.Date.ToString("dd/MM/yyyy")</div>
                            <div class="fw-bold text-dark">@item.TimeSlot</div>
                        </td>
                        <td>
                            @{
                                var bClass = item.Status switch
                                {
                                    "Đã hoàn thành" => "bg-success",
                                    "Đã có đối thủ" => "bg-success",
                                    "Đang chờ đối thủ" => "bg-warning text-dark",
                                    "Đã hủy" => "bg-danger",
                                    _ => "bg-primary"
                                };
                            }
                            <span class="badge @bClass rounded-pill px-3">@item.Status</span>
                        </td>
                        <td class="text-center">
                            @if (item.Type == "Kèo ghép" && item.Status == "Đang chờ đối thủ")
                            {
                                <button type="button" class="btn btn-sm btn-success rounded-pill px-3 fw-bold shadow-sm"
                                        onclick="openAcceptModal('@item.CustomerName', @item.Id)">
                                    <i class="bi bi-qr-code-scan me-1"></i> Nhận Kèo
                                </button>
                            }
                            else if (item.Type == "Đặt sân lẻ")
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    <i class="bi bi-pencil-square"></i> Xử lý
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small italic">Đã chốt</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>